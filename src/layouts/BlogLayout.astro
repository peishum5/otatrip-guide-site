---
import BaseLayout from './BaseLayout.astro';
import ArticleCTA from '../components/ArticleCTA.astro';

interface Props {
  title: string;
  description?: string;
  pubDate?: string;
  last_updated?: string;
  author?: string;
  canonical?: string;
  hero_image?: string;
  category?: string;
}

const { title, description, pubDate, last_updated, author = 'Local Guide', canonical, hero_image, category } = Astro.props;
const displayDate = last_updated || pubDate;
---

<BaseLayout title={title} description={description} canonical={canonical} ogImage={hero_image}>
  <article class="max-w-3xl mx-auto px-4 py-10">
    <!-- Breadcrumb -->
    <nav class="font-pixel text-[0.35rem] text-gray-600 mb-8 flex items-center gap-2 flex-wrap" aria-label="Breadcrumb">
      <a href="/" class="hover:text-nes-amber transition-colors">HOME</a>
      <span class="text-nes-amber">&gt;</span>
      <a href="/blog" class="hover:text-nes-amber transition-colors">BLOG</a>
      {category && (
        <>
          <span class="text-nes-amber">&gt;</span>
          <span class="text-gray-500">{category.toUpperCase()}</span>
        </>
      )}
    </nav>

    <!-- Hero image -->
    {hero_image && hero_image !== '' && (
      <div class="mb-8 border-2 border-gray-700 overflow-hidden">
        <img src={hero_image} alt={title} class="w-full h-64 md:h-80 object-cover" loading="eager" />
      </div>
    )}

    <!-- Title + meta -->
    <header class="mb-10 border-b border-gray-800 pb-8">
      <p class="font-pixel text-[0.35rem] text-nes-cyan mb-4 rpg-prefix">{category ? category.toUpperCase() : 'KYOTO GUIDE'}</p>
      <h1 class="font-pixel text-nes-white leading-relaxed mb-6" style="font-size: clamp(0.7rem, 2.5vw, 1rem);">{title}</h1>
      <div class="flex flex-wrap items-center gap-6 font-pixel text-[0.35rem] text-gray-600">
        <span class="rpg-prefix">{author}</span>
        {displayDate && displayDate !== '' && (
          <span class="rpg-prefix">UPDATED: {displayDate}</span>
        )}
      </div>
    </header>

    <!-- Content — prose stays font-sans for readability -->
    <div class="prose prose-lg max-w-none font-sans">
      <slot />
    </div>

    <!-- CTA -->
    <ArticleCTA />

    <!-- Author box -->
    <div class="mt-10 border-t border-gray-800 pt-8 flex items-start gap-4">
      <div class="w-12 h-12 border-2 border-nes-amber bg-nes-black flex items-center justify-center shrink-0">
        <span class="font-pixel text-[0.5rem] text-nes-amber">LG</span>
      </div>
      <div>
        <div class="font-pixel text-[0.45rem] text-nes-white mb-2">{author}</div>
        <p class="font-sans text-sm text-gray-500 leading-relaxed">
          Local guide based in Gion, Kyoto. Leading intimate walking tours and sake experiences since 2018.
          Passionate about connecting travelers with authentic Kyoto culture.
        </p>
      </div>
    </div>
  </article>
</BaseLayout>
