---
import BaseLayout from './BaseLayout.astro';
import ArticleCTA from '../components/ArticleCTA.astro';

interface FAQ {
  q: string;
  a: string;
}

interface RelatedPost {
  slug: string;
  title: string;
  description: string;
  hero_image?: string;
}

interface Props {
  title: string;
  description?: string;
  pubDate?: string;
  last_updated?: string;
  author?: string;
  canonical?: string;
  hero_image?: string;
  category?: string;
  categoryHref?: string;
  keywords?: string[];
  faq?: FAQ[];
  relatedPosts?: RelatedPost[];
  noIndex?: boolean;
}

const {
  title,
  description,
  pubDate,
  last_updated,
  author = 'OTAtrip Guide',
  canonical,
  hero_image,
  category,
  categoryHref,
  keywords = [],
  faq = [],
  relatedPosts = [],
  noIndex,
} = Astro.props;
const displayDate = last_updated || pubDate;
const siteUrl = (Astro.site ?? new URL('https://otatrip.guide')).origin;
const canonicalPath = canonical || Astro.url.pathname;
const canonicalUrl = new URL(canonicalPath, siteUrl).toString();
const imageUrl = hero_image ? new URL(hero_image, siteUrl).toString() : new URL('/images/og-default.jpg', siteUrl).toString();
const graph: Record<string, unknown>[] = [
  {
    "@type": "Article",
    "headline": title,
    "description": description,
    "author": {
      "@type": "Person",
      "name": author
    },
    "datePublished": pubDate || displayDate,
    "dateModified": displayDate || pubDate,
    "mainEntityOfPage": canonicalUrl,
    "image": [imageUrl],
    "publisher": {
      "@type": "Organization",
      "name": "OTAtrip Guide",
      "url": siteUrl
    }
  },
  {
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Home",
        "item": siteUrl
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": "Blog",
        "item": `${siteUrl}/blog`
      },
      {
        "@type": "ListItem",
        "position": 3,
        "name": title,
        "item": canonicalUrl
      }
    ]
  }
];

if (faq.length > 0) {
  graph.push({
    "@type": "FAQPage",
    "mainEntity": faq.map((item) => ({
      "@type": "Question",
      "name": item.q,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": item.a
      }
    }))
  });
}
---

<BaseLayout
  title={title}
  description={description}
  canonical={canonical}
  ogImage={hero_image}
  ogType="article"
  keywords={keywords}
  publishedTime={pubDate}
  modifiedTime={displayDate}
  noIndex={noIndex}
>
  <article class="max-w-3xl mx-auto px-4 py-10">

    <!-- Breadcrumb -->
    <nav class="font-pixel text-[0.9rem] text-gray-600 mb-8 flex items-center gap-2 flex-wrap" aria-label="Breadcrumb">
      <a href="/" class="hover:text-nes-amber transition-colors">HOME</a>
      <span class="text-gray-700">/</span>
      <a href="/blog" class="hover:text-nes-amber transition-colors">BLOG</a>
      {category && (
        <>
          <span class="text-gray-700">/</span>
          {categoryHref ? (
            <a href={categoryHref} class="hover:text-nes-amber transition-colors">{category.toUpperCase()}</a>
          ) : (
            <span class="text-gray-500">{category.toUpperCase()}</span>
          )}
        </>
      )}
    </nav>

    <!-- Hero image -->
    {hero_image && hero_image !== '' && (
      <div class="mb-8 border-2 border-gray-700 overflow-hidden">
        <img src={hero_image} alt={title} class="w-full h-64 md:h-80 object-cover" loading="eager" />
      </div>
    )}

    <!-- Title + meta -->
    <header class="mb-10 border-b border-gray-800 pb-8">
      <p class="font-pixel text-[0.9rem] text-nes-cyan mb-3">{(category || 'Kyoto Guide').toUpperCase()}</p>
      <h1 class="font-pixel text-nes-white leading-relaxed mb-5" style="font-size: clamp(0.75rem, 2.5vw, 1rem);">{title}</h1>
      <div class="flex flex-wrap items-center gap-4 font-pixel text-[0.9rem] text-gray-600">
        <span>BY {author.toUpperCase()}</span>
        {displayDate && displayDate !== '' && (
          <time datetime={displayDate}>UPDATED: {displayDate}</time>
        )}
      </div>
    </header>

    <!-- Content — prose for readability -->
    <div class="prose prose-lg max-w-none font-sans">
      <slot />
    </div>

    <!-- CTA -->
    <ArticleCTA />

    {faq.length > 0 && (
      <section class="mt-10 border-t border-gray-800 pt-8">
        <div class="flex items-center gap-4 mb-6">
          <h2 class="font-pixel text-[0.9rem] text-nes-amber">FAQ</h2>
          <div class="flex-1 border-t border-gray-800"></div>
        </div>
        <div class="space-y-3">
          {faq.map((item) => (
            <details class="border border-gray-800 bg-gray-900 group">
              <summary class="flex items-center justify-between px-5 py-4 cursor-pointer font-pixel text-[0.9rem] text-nes-white hover:text-nes-amber transition-colors">
                {item.q}
                <span class="ml-4 text-gray-600 shrink-0 group-open:rotate-180 transition-transform">▼</span>
              </summary>
              <div class="px-5 pb-4 pt-4 font-sans text-sm text-gray-400 leading-relaxed border-t border-gray-800">
                {item.a}
              </div>
            </details>
          ))}
        </div>
      </section>
    )}

    {relatedPosts.length > 0 && (
      <section class="mt-10 border-t border-gray-800 pt-8">
        <div class="flex items-center gap-4 mb-6">
          <h2 class="font-pixel text-[0.9rem] text-nes-cyan">RELATED GUIDES</h2>
          <div class="flex-1 border-t border-gray-800"></div>
        </div>
        <div class="grid md:grid-cols-3 gap-4">
          {relatedPosts.map((item) => (
            <article class="border border-gray-800 bg-gray-950 hover:border-nes-amber transition-colors">
              <a href={`/blog/${item.slug}`} class="block">
                {item.hero_image && (
                  <img src={item.hero_image} alt={item.title} class="w-full h-32 object-cover border-b border-gray-800" loading="lazy" />
                )}
                <div class="p-4">
                  <h3 class="font-pixel text-[0.9rem] text-nes-white leading-relaxed mb-3">{item.title}</h3>
                  <p class="font-sans text-sm text-gray-500 leading-relaxed line-clamp-3">{item.description}</p>
                </div>
              </a>
            </article>
          ))}
        </div>
      </section>
    )}

    <!-- Author box -->
    <div class="mt-10 border-t border-gray-800 pt-8 flex items-start gap-4">
      <div class="w-12 h-12 border-2 border-nes-amber bg-nes-black flex items-center justify-center shrink-0">
        <span class="font-pixel text-[0.9rem] text-nes-amber">OG</span>
      </div>
      <div>
        <div class="font-pixel text-[0.9rem] text-nes-white mb-1">{author.toUpperCase()}</div>
        <p class="font-sans text-sm text-gray-500 leading-relaxed">
          Local guide based in Gion, Kyoto. Leading intimate walking tours and sake experiences since 2018.
          Passionate about connecting travelers with authentic Kyoto culture.
        </p>
      </div>
    </div>

  </article>

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@graph": graph
  })} />
</BaseLayout>
