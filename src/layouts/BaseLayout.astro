---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  noIndex?: boolean;
}

const {
  title,
  description = 'Explore Kyoto with local expert guides. Book the Kyoto Gion Night Walk or discover our travel guides for first-timers.',
  canonical,
  ogImage,
  noIndex = false,
} = Astro.props;

const siteUrl = 'https://otatrip-guide.com';
const canonicalUrl = canonical ? `${siteUrl}${canonical}` : `${siteUrl}${Astro.url.pathname}`;
const ogImageUrl = ogImage || `${siteUrl}/images/og-default.jpg`;
const fullTitle = title.includes('OTA Trip Guide') ? title : `${title} | OTA Trip Guide`;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  {noIndex && <meta name="robots" content="noindex,nofollow" />}
  <link rel="canonical" href={canonicalUrl} />

  <!-- Open Graph -->
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:image" content={ogImageUrl} />
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="OTA Trip Guide" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImageUrl} />

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- Page-specific head injections (e.g. Bokun widget script) -->
  <slot name="head" />

  <!-- Google Analytics 4 -->
  {import.meta.env.PROD && (
    <>
      <script async src="https://www.googletagmanager.com/gtag/js?id=G-7NL28Z41JD" is:inline></script>
      <script is:inline>
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        gtag('js', new Date());
        gtag('config', 'G-7NL28Z41JD');
      </script>
    </>
  )}

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Press+Start+2P&display=swap" rel="stylesheet" />
</head>
<body class="bg-nes-black text-nes-white font-sans antialiased">
  <Header />
  <main>
    <slot />
  </main>
  <Footer />
</body>
</html>
