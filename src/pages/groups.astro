---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Group Tours Kyoto — OTAtrip Guide"
  description="Private group walking tours in Gion, Higashiyama, and Kiyomizu. Flexible arrangements for any group size. Just get in touch."
  canonical="/groups"
>
  <!-- Header -->
  <section class="scanlines bg-nes-black py-16 text-center">
    <div class="relative z-10 max-w-3xl mx-auto px-4">
      <p class="font-pixel text-[0.5rem] text-nes-amber mb-4 rpg-prefix">PARTY MODE</p>
      <h1 class="font-pixel text-nes-white mb-4" style="font-size: clamp(1rem, 4vw, 2rem);">GROUP QUESTS</h1>
      <p class="font-sans text-gray-400 text-sm max-w-xl mx-auto">
        Bringing a group to Kyoto? We're happy to figure something out together.
      </p>
    </div>
  </section>

  <div class="max-w-3xl mx-auto px-4 py-12">

    <!-- What we do -->
    <section class="mb-12">
      <div class="dialogue-box">
        <p class="font-pixel text-[0.5rem] text-nes-cyan mb-4">// ABOUT</p>
        <p class="font-sans text-gray-300 text-sm leading-relaxed mb-4">
          We're not a travel agency — we're local guides who love showing people around Kyoto.
          Our home turf is the <span class="text-nes-amber font-medium">Gion, Higashiyama, and Kiyomizu</span> area,
          and we can put together a walking experience that fits your group.
        </p>
        <p class="font-sans text-gray-300 text-sm leading-relaxed">
          Group size, timing, pace, theme — just tell us what you're after and we'll see what we can do.
          No pressure. First message is always free.
        </p>
      </div>
    </section>

    <!-- What's flexible -->
    <section class="mb-12">
      <div class="flex items-center gap-4 mb-6">
        <h2 class="font-pixel text-[0.5rem] text-nes-amber">WHAT WE CAN WORK WITH</h2>
        <div class="flex-1 border-t border-gray-800"></div>
      </div>
      <div class="grid sm:grid-cols-2 gap-4">
        {[
          { icon: '🗺️', title: 'Area', desc: 'Gion, Higashiyama, Kiyomizu-dera — the heart of old Kyoto.' },
          { icon: '👥', title: 'Group Size', desc: 'Small groups to larger parties. We split big groups to keep it intimate.' },
          { icon: '🕐', title: 'Timing', desc: 'Morning, afternoon, or night walks. We work around your schedule.' },
          { icon: '🌐', title: 'Language', desc: 'English tours as standard. Japanese support available.' },
        ].map(item => (
          <div class="dialogue-box flex gap-4 items-start">
            <span class="text-2xl shrink-0">{item.icon}</span>
            <div>
              <p class="font-sans text-sm font-semibold text-nes-white mb-1">{item.title}</p>
              <p class="font-sans text-xs text-gray-400 leading-relaxed">{item.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- How it works -->
    <section class="mb-12">
      <div class="flex items-center gap-4 mb-6">
        <h2 class="font-pixel text-[0.5rem] text-nes-amber">HOW IT WORKS</h2>
        <div class="flex-1 border-t border-gray-800"></div>
      </div>
      <div class="space-y-4">
        {[
          { step: '01', text: 'Drop us a message with your group size, dates, and what kind of experience you\'re after.' },
          { step: '02', text: 'We\'ll get back to you within 24 hours with ideas and a quote.' },
          { step: '03', text: 'We lock in the plan together. No complicated contracts.' },
        ].map(item => (
          <div class="flex gap-5 items-start">
            <div class="font-pixel text-[0.5rem] text-nes-cyan shrink-0 w-8 text-right">{item.step}</div>
            <div class="flex-1 border-t border-gray-800 pt-3">
              <p class="font-sans text-sm text-gray-300 leading-relaxed">{item.text}</p>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Contact form -->
    <section id="contact-form" class="mb-12">
      <div class="dialogue-box">
        <p class="font-pixel text-[0.5rem] text-nes-cyan mb-6">// SEND A MESSAGE</p>

        <form
          name="group-inquiry"
          method="POST"
          action="/contact/success"
          class="space-y-5"
          data-netlify="true"
        >
          <input type="hidden" name="form-name" value="group-inquiry" />

          <div class="grid sm:grid-cols-2 gap-5">
            <div>
              <label for="name" class="block font-sans text-xs text-gray-400 mb-2">Your Name *</label>
              <input
                type="text"
                id="name"
                name="name"
                required
                class="w-full bg-gray-900 border-2 border-gray-700 focus:border-nes-amber px-4 py-3 text-sm text-nes-white outline-none transition-colors"
                placeholder="Your name"
              />
            </div>
            <div>
              <label for="email" class="block font-sans text-xs text-gray-400 mb-2">Email Address *</label>
              <input
                type="email"
                id="email"
                name="email"
                required
                class="w-full bg-gray-900 border-2 border-gray-700 focus:border-nes-amber px-4 py-3 text-sm text-nes-white outline-none transition-colors"
                placeholder="you@example.com"
              />
            </div>
          </div>

          <div class="grid sm:grid-cols-2 gap-5">
            <div>
              <label for="group-size" class="block font-sans text-xs text-gray-400 mb-2">Group Size</label>
              <select
                id="group-size"
                name="group-size"
                class="w-full bg-gray-900 border-2 border-gray-700 focus:border-nes-amber px-4 py-3 text-sm text-nes-white outline-none transition-colors"
              >
                <option value="">Select...</option>
                <option value="2-4">2–4 guests</option>
                <option value="5-8">5–8 guests</option>
                <option value="9-15">9–15 guests</option>
                <option value="16+">16+ guests</option>
              </select>
            </div>
            <div>
              <label for="preferred-date" class="block font-sans text-xs text-gray-400 mb-2">Preferred Date(s)</label>
              <input
                type="text"
                id="preferred-date"
                name="preferred-date"
                class="w-full bg-gray-900 border-2 border-gray-700 focus:border-nes-amber px-4 py-3 text-sm text-nes-white outline-none transition-colors"
                placeholder="e.g. April 10–12"
              />
            </div>
          </div>

          <div>
            <label for="message" class="block font-sans text-xs text-gray-400 mb-2">What are you looking for?</label>
            <textarea
              id="message"
              name="message"
              rows="4"
              class="w-full bg-gray-900 border-2 border-gray-700 focus:border-nes-amber px-4 py-3 text-sm text-nes-white outline-none transition-colors resize-none"
              placeholder="Tell us about your group and what kind of Kyoto experience you have in mind."
            ></textarea>
          </div>

          <button type="submit" class="nes-btn nes-btn-gold w-full">
            Send Message
          </button>
        </form>
      </div>
    </section>

    <!-- Back link -->
    <div class="text-center">
      <a href="/" class="font-pixel text-[0.5rem] text-nes-amber hover:text-nes-cyan transition-colors">
        &lt; BACK TO QUEST SELECT
      </a>
    </div>

  </div>
</BaseLayout>
