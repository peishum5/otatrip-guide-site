---
import BaseLayout from '../layouts/BaseLayout.astro';

const features = [
  {
    icon: '🗓️',
    title: 'Flexible Scheduling',
    desc: 'We work around your group\'s itinerary. Morning, afternoon, or evening departures available on request.',
  },
  {
    icon: '🗺️',
    title: 'Custom Routes',
    desc: 'Standard Gion route or tailored variants — Fushimi sake district, tea ceremony add-ons, themed cultural walks.',
  },
  {
    icon: '💼',
    title: 'Agency-Friendly',
    desc: 'Net rates for travel agencies, invoicing in JPY or USD, and documentation for package inclusion.',
  },
  {
    icon: '🌐',
    title: 'Multilingual',
    desc: 'English-language tours with Japanese support available. Interpretation partnerships for other languages on request.',
  },
  {
    icon: '👥',
    title: 'Groups of Any Size',
    desc: 'From 4 to 40+ guests. We split large groups into parallel small-group experiences for quality.',
  },
  {
    icon: '⭐',
    title: 'Proven Track Record',
    desc: '200+ guests guided, 4.9/5 rating. References from travel agencies and corporate clients available.',
  },
];

const faqs = [
  {
    q: 'What is the minimum group size for a private tour?',
    a: 'We accept private bookings from 2 guests upward. For groups of 4+, we offer preferential group rates.',
  },
  {
    q: 'How do you handle large groups (20+ people)?',
    a: 'Groups of 9+ are split into parallel small groups (max 8 each), each with a dedicated guide. This maintains quality and intimacy.',
  },
  {
    q: 'Do you offer commission to travel agencies?',
    a: 'Yes. We have a standard net rate structure for registered travel agencies. Contact us to discuss terms.',
  },
  {
    q: 'Can you provide custom itineraries beyond the Gion Sake Walk?',
    a: 'Yes. We can design custom Kyoto experiences including Fushimi sake district visits, tea ceremony combinations, Nishiki Market walks, and more.',
  },
  {
    q: 'What notice do you need for large group bookings?',
    a: 'We recommend 2–4 weeks notice for groups of 10+, and 1+ month for groups of 20+. Last-minute requests are considered based on availability.',
  },
  {
    q: 'Do you provide invoices and receipts?',
    a: 'Yes. We issue invoices in JPY or USD with all details required for business accounting and tour package documentation.',
  },
];
---

<BaseLayout
  title="Group Tours & Travel Agency Services — OTA Trip Guide Kyoto"
  description="Private Gion sake walking tours for travel agencies, corporate groups, and tour operators. Flexible scheduling, custom routes, agency net rates. Kyoto local experts."
  canonical="/groups"
>
  <!-- Hero -->
  <section class="bg-navy-dark text-white py-16 md:py-20">
    <div class="max-w-4xl mx-auto px-4">
      <div class="text-gold text-xs font-bold uppercase tracking-widest mb-4">Travel Agencies &amp; Group Tours</div>
      <h1 class="text-4xl md:text-5xl font-bold leading-tight mb-6">
        Group &amp; Agency<br />
        <span class="text-gold">Partner Program</span>
      </h1>
      <p class="text-gray-300 text-xl leading-relaxed max-w-2xl mb-8">
        We partner with travel agencies, tour operators, and corporate event planners to deliver
        authentic Kyoto experiences for groups of any size. Custom itineraries, flexible pricing,
        and dedicated local guides.
      </p>
      <div class="flex flex-wrap gap-4">
        <a href="#contact-form" class="bg-gold hover:bg-gold-light text-navy-dark font-bold px-8 py-4 rounded-lg transition-colors">
          Send Inquiry
        </a>
        <a href="/tours/gion-sake-walk" class="border border-white/40 text-white hover:border-gold hover:text-gold font-medium px-8 py-4 rounded-lg transition-colors">
          View Tour Details
        </a>
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="bg-navy text-white">
    <div class="max-w-4xl mx-auto px-4 py-8">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
        {[
          { number: '200+', label: 'Guests Guided' },
          { number: '4.9★', label: 'Average Rating' },
          { number: '6+', label: 'Years Operating' },
          { number: '15+', label: 'Partner Agencies' },
        ].map(stat => (
          <div>
            <div class="text-gold text-2xl font-bold">{stat.number}</div>
            <div class="text-gray-400 text-sm mt-1">{stat.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <div class="max-w-4xl mx-auto px-4 py-12">

    <!-- What We Offer -->
    <section class="mb-14">
      <div class="text-gold text-xs font-bold uppercase tracking-widest mb-2">What We Offer</div>
      <h2 class="text-3xl font-bold text-navy-dark mb-8">Built for Professional Partners</h2>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {features.map(f => (
          <div class="bg-gray-50 rounded-xl p-6">
            <div class="text-3xl mb-3">{f.icon}</div>
            <h3 class="font-bold text-navy-dark mb-2">{f.title}</h3>
            <p class="text-gray-600 text-sm leading-relaxed">{f.desc}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- How It Works -->
    <section class="mb-14">
      <h2 class="text-2xl font-bold text-navy-dark mb-8">How to Book a Group Tour</h2>
      <div class="grid md:grid-cols-3 gap-6">
        {[
          {
            step: '01',
            title: 'Send Inquiry',
            desc: 'Fill out the form below with your group size, preferred dates, and any special requirements.',
          },
          {
            step: '02',
            title: 'We Confirm',
            desc: 'We respond within 24 hours with availability, custom options, and a detailed quote.',
          },
          {
            step: '03',
            title: 'Confirm & Pay',
            desc: 'Accept the proposal, sign our simple agreement, and pay by bank transfer or card.',
          },
        ].map(item => (
          <div class="text-center">
            <div class="w-12 h-12 bg-navy-dark text-gold font-bold text-lg rounded-full flex items-center justify-center mx-auto mb-4">
              {item.step}
            </div>
            <h3 class="font-bold text-navy-dark mb-2">{item.title}</h3>
            <p class="text-gray-500 text-sm leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Contact Form -->
    <section id="contact-form" class="mb-14 bg-gray-50 rounded-2xl p-8 md:p-10">
      <div class="text-gold text-xs font-bold uppercase tracking-widest mb-2">Group Inquiry</div>
      <h2 class="text-2xl font-bold text-navy-dark mb-6">Send Us a Message</h2>

      <form
        name="group-inquiry"
        method="POST"
        action="/contact/success"
        class="space-y-5"
        data-netlify="true"
      >
        <input type="hidden" name="form-name" value="group-inquiry" />

        <div class="grid md:grid-cols-2 gap-5">
          <div>
            <label for="name" class="block text-sm font-medium text-gray-700 mb-1">Your Name *</label>
            <input
              type="text"
              id="name"
              name="name"
              required
              class="w-full border border-gray-300 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-gold focus:border-transparent"
              placeholder="Jane Smith"
            />
          </div>
          <div>
            <label for="company" class="block text-sm font-medium text-gray-700 mb-1">Company / Agency</label>
            <input
              type="text"
              id="company"
              name="company"
              class="w-full border border-gray-300 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-gold focus:border-transparent"
              placeholder="Example Travel Co."
            />
          </div>
        </div>

        <div>
          <label for="email" class="block text-sm font-medium text-gray-700 mb-1">Email Address *</label>
          <input
            type="email"
            id="email"
            name="email"
            required
            class="w-full border border-gray-300 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-gold focus:border-transparent"
            placeholder="jane@exampletravel.com"
          />
        </div>

        <div class="grid md:grid-cols-2 gap-5">
          <div>
            <label for="group-size" class="block text-sm font-medium text-gray-700 mb-1">Group Size *</label>
            <select
              id="group-size"
              name="group-size"
              required
              class="w-full border border-gray-300 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-gold focus:border-transparent bg-white"
            >
              <option value="">Select size...</option>
              <option value="2-4">2–4 guests</option>
              <option value="5-8">5–8 guests</option>
              <option value="9-15">9–15 guests</option>
              <option value="16-30">16–30 guests</option>
              <option value="30+">30+ guests</option>
            </select>
          </div>
          <div>
            <label for="preferred-date" class="block text-sm font-medium text-gray-700 mb-1">Preferred Date(s)</label>
            <input
              type="text"
              id="preferred-date"
              name="preferred-date"
              class="w-full border border-gray-300 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-gold focus:border-transparent"
              placeholder="e.g. May 10–15, 2025"
            />
          </div>
        </div>

        <div>
          <label for="message" class="block text-sm font-medium text-gray-700 mb-1">Message / Special Requirements</label>
          <textarea
            id="message"
            name="message"
            rows="5"
            class="w-full border border-gray-300 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-gold focus:border-transparent resize-none"
            placeholder="Tell us about your group, any special requirements, preferred time of day, language needs, etc."
          ></textarea>
        </div>

        <button
          type="submit"
          class="w-full md:w-auto bg-gold hover:bg-gold-light text-navy-dark font-bold px-10 py-3 rounded-lg transition-colors"
        >
          Send Inquiry
        </button>
      </form>
    </section>

    <!-- FAQ -->
    <section class="mb-12">
      <h2 class="text-2xl font-bold text-navy-dark mb-6">Frequently Asked Questions</h2>
      <div class="space-y-3">
        {faqs.map(faq => (
          <details class="border border-gray-200 rounded-lg overflow-hidden group">
            <summary class="flex items-center justify-between px-6 py-4 cursor-pointer font-medium text-navy-dark hover:text-gold transition-colors">
              {faq.q}
              <span class="ml-4 text-gray-400 group-open:rotate-180 transition-transform shrink-0">&#9660;</span>
            </summary>
            <div class="px-6 pb-5 text-gray-600 text-sm leading-relaxed border-t border-gray-100 pt-4">
              {faq.a}
            </div>
          </details>
        ))}
      </div>
    </section>

  </div>
</BaseLayout>
