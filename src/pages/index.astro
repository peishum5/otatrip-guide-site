---
import BaseLayout from '../layouts/BaseLayout.astro';
import GroupCTA from '../components/GroupCTA.astro';
import ReviewsSection from '../components/ReviewsSection.astro';
import { getCollection } from 'astro:content';

const blogPosts = await getCollection('blog');
const latestPosts = blogPosts.slice(0, 3);
---

<BaseLayout
  title="OTAtrip Guide — Kyoto Local Tours & Travel Guides"
  description="Explore Kyoto with local expert guides. Rated 4.9/5 on TripAdvisor. Book a walking tour or browse our practical travel guides for first-time visitors."
>
  <!-- Hero Section -->
  <section class="scanlines relative bg-nes-black text-nes-white overflow-hidden">
    <img
      src="/images/tours/tour-kiyomizu-night.jpg"
      alt="Gion night walking tour guests"
      class="absolute inset-0 w-full h-full object-cover opacity-70"
      loading="eager"
    />
    <div class="relative z-10 max-w-6xl mx-auto px-4 py-20 md:py-32">

      <!-- Rating badge -->
      <div id="hero-badge" class="hero-reveal inline-flex items-center gap-3 border border-nes-amber px-4 py-2 mb-6" style="--d:0.2s">
        <span class="text-nes-amber text-sm">★★★★★</span>
        <span class="font-pixel text-[0.9rem] text-nes-white">4.9 / 5</span>
        <span class="font-sans text-xs text-gray-400">on TripAdvisor</span>
      </div>

      <!-- Typewriter h1 -->
      <h1 id="hero-h1" class="font-pixel text-nes-amber leading-relaxed mb-6" style="font-size: clamp(0.9rem, 3vw, 1.5rem); min-height: 3.5em;">
        <span id="hero-line1"></span><span id="hero-cursor" class="hero-cursor">█</span><br />
        <span id="hero-line2" class="text-nes-white"></span>
      </h1>

      <!-- Description -->
      <p id="hero-desc" class="hero-reveal font-sans text-gray-300 text-lg leading-relaxed mb-8 max-w-xl" style="--d:0s; opacity:0">
        Intimate walking tours through Gion's lantern-lit alleys. Sake tastings at bars only locals know.
        Small groups, genuine experiences.
      </p>

      <!-- Buttons -->
      <div id="hero-btns" class="hero-reveal flex flex-col sm:flex-row gap-5" style="--d:0s; opacity:0">
        <a href="/tours" class="nes-btn nes-btn-gold">SEE ALL TOURS</a>
        <a href="/blog" class="nes-btn nes-btn-outline">BROWSE TRAVEL GUIDES</a>
      </div>
    </div>
  </section>

  <style>
    /* hero element reveal */
    @keyframes heroFadeUp {
      from { opacity: 0; transform: translateY(10px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    .hero-reveal {
      opacity: 0;
      animation: heroFadeUp 0.6s ease forwards;
      animation-delay: var(--d, 0s);
    }

    /* blinking block cursor */
    @keyframes blockBlink {
      0%, 49% { opacity: 1; }
      50%, 100% { opacity: 0; }
    }
    .hero-cursor {
      display: inline-block;
      animation: blockBlink 0.7s step-end infinite;
    }

    /* glitch twitch */
    @keyframes glitchTwitch {
      0%   { transform: translate(0); }
      20%  { transform: translate(-3px, 1px); filter: brightness(1.3); }
      40%  { transform: translate(3px, -1px); }
      60%  { transform: translate(-2px, 0); }
      80%  { transform: translate(2px, 1px); filter: brightness(0.9); }
      100% { transform: translate(0); filter: none; }
    }
    #hero-h1.glitch {
      animation: glitchTwitch 0.15s steps(1) forwards;
    }
  </style>

  <script>
  (() => {
    const L1 = 'DISCOVER KYOTO';
    const L2 = 'LIKE A LOCAL';
    const SPEED = 60; // ms per char

    const el1    = document.getElementById('hero-line1');
    const el2    = document.getElementById('hero-line2');
    const cursor = document.getElementById('hero-cursor');
    const desc   = document.getElementById('hero-desc');
    const btns   = document.getElementById('hero-btns');
    const h1     = document.getElementById('hero-h1');

    function typeText(el, text, cb) {
      let i = 0;
      const t = setInterval(() => {
        el.textContent += text[i++];
        if (i >= text.length) { clearInterval(t); if (cb) cb(); }
      }, SPEED);
    }

    // Start after badge fades in
    setTimeout(() => {
      typeText(el1, L1, () => {
        // Move cursor to line2 position
        setTimeout(() => {
          el2.appendChild(cursor); // move cursor to line2
          typeText(el2, L2, () => {
            // Typing done — reveal desc & buttons
            desc.style.setProperty('--d', '0.1s');
            desc.style.removeProperty('opacity');
            desc.classList.add('hero-reveal');

            setTimeout(() => {
              btns.style.setProperty('--d', '0.1s');
              btns.style.removeProperty('opacity');
              btns.classList.add('hero-reveal');
            }, 300);

            // Start periodic glitch after a short pause
            setTimeout(startGlitch, 2000);
          });
        }, 220);
      });
    }, 600);

    function startGlitch() {
      function glitch() {
        h1.classList.add('glitch');
        setTimeout(() => h1.classList.remove('glitch'), 200);
        // Schedule next glitch randomly 4–9s later
        setTimeout(glitch, 4000 + Math.random() * 5000);
      }
      glitch();
    }
  })();
  </script>

  <!-- Stats Bar -->
  <section class="bg-nes-black border-y-2 border-nes-amber">
    <div class="max-w-6xl mx-auto px-4 py-8">
      <p class="font-pixel text-[0.9rem] text-nes-cyan text-center mb-6">-- PLAYER STATS --</p>
      <div class="grid grid-cols-3 gap-6 text-center">
        {[
          { number: '1000+', label: 'Guests Guided' },
          { number: '4.9★', label: 'TripAdvisor Rating' },
          { number: '2024', label: 'Year Founded' },
        ].map(stat => (
          <div>
            <div class="nes-number text-2xl md:text-3xl mb-1">{stat.number}</div>
            <div class="font-sans text-xs text-gray-500 mt-1">{stat.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Reviews -->
  <section class="max-w-6xl mx-auto px-4">
    <ReviewsSection />
  </section>

  <!-- Tours teaser -->
  <section class="max-w-6xl mx-auto px-4 pb-16">
    <div class="flex items-end justify-between mb-8">
      <div>
        <p class="font-pixel text-[0.9rem] text-nes-amber mb-2 rpg-prefix">AVAILABLE QUESTS</p>
        <h2 class="font-pixel text-nes-white leading-relaxed" style="font-size: clamp(0.65rem, 2vw, 0.9rem);">
          OUR TOURS
        </h2>
      </div>
      <a href="/tours" class="font-pixel text-[0.9rem] text-nes-cyan hover:text-nes-amber transition-colors hidden md:block">
        ALL TOURS &gt;
      </a>
    </div>
    <div class="dialogue-box flex flex-col md:flex-row items-center gap-6">
      <div class="text-5xl shrink-0">🏮</div>
      <div class="flex-1">
        <p class="font-pixel text-[0.9rem] text-nes-cyan mb-2">EVENING TOUR · GION DISTRICT</p>
        <h3 class="font-pixel text-[1rem] text-nes-white leading-relaxed mb-2">GION SAKE WALKING TOUR</h3>
        <p class="font-sans text-sm text-gray-300">3 hours · Max 8 guests · 3 sake bars · English</p>
      </div>
      <a href="/tours/gion-sake-walk" class="nes-btn nes-btn-gold shrink-0">VIEW TOUR</a>
    </div>
    <div class="text-center mt-6 md:hidden">
      <a href="/tours" class="font-pixel text-[0.9rem] text-nes-cyan hover:text-nes-amber transition-colors">ALL TOURS &gt;</a>
    </div>
  </section>

  <!-- B2B Group CTA -->
  <section class="max-w-6xl mx-auto px-4">
    <GroupCTA />
  </section>

  <!-- Latest Blog Posts -->
  <section class="max-w-6xl mx-auto px-4 py-16">
    <div class="flex items-end justify-between mb-8">
      <div>
        <p class="font-pixel text-[0.9rem] text-nes-amber mb-2 rpg-prefix">TRAVEL GUIDES</p>
        <h2 class="font-pixel text-nes-white leading-relaxed" style="font-size: clamp(0.65rem, 2vw, 0.9rem);">
          PLAN YOUR KYOTO TRIP
        </h2>
      </div>
      <a href="/blog" class="font-pixel text-[0.9rem] text-nes-cyan hover:text-nes-amber transition-colors hidden md:block">
        ALL GUIDES &gt;
      </a>
    </div>

    {latestPosts.length > 0 ? (
      <div class="grid md:grid-cols-3 gap-6">
        {latestPosts.map(post => (
          <article class="border-2 border-gray-700 hover:border-nes-amber transition-colors group bg-nes-black">
            <a href={`/blog/${post.slug}`} class="block">
              <div class="bg-gray-900 border-b border-gray-700 h-36 flex items-end p-4">
                <span class="font-sans text-xs text-nes-amber font-medium">{post.data.category || 'Kyoto Guide'}</span>
              </div>
              <div class="p-5">
                <h3 class="font-pixel text-[0.9rem] text-nes-white group-hover:text-nes-amber transition-colors leading-relaxed mb-3 line-clamp-2">
                  {post.data.title}
                </h3>
                <p class="font-sans text-gray-500 text-sm leading-relaxed line-clamp-3">{post.data.description}</p>
                <div class="mt-4 font-sans text-xs text-nes-cyan font-medium">Read guide &rarr;</div>
              </div>
            </a>
          </article>
        ))}
      </div>
    ) : (
      <p class="font-pixel text-[0.9rem] text-gray-600 text-center py-12">// BLOG POSTS COMING SOON</p>
    )}
  </section>

  <!-- Why Choose Us -->
  <section class="bg-nes-black border-y-2 border-gray-800 py-16">
    <div class="max-w-6xl mx-auto px-4">
      <div class="text-center mb-12">
        <p class="font-pixel text-[0.9rem] text-nes-cyan mb-4 rpg-prefix">WHY OTAtrip GUIDE</p>
        <h2 class="font-pixel text-nes-white leading-relaxed" style="font-size: clamp(0.65rem, 2vw, 0.9rem);">
          KYOTO FROM THE INSIDE
        </h2>
      </div>
      <div class="grid md:grid-cols-3 gap-8">
        {[
          {
            icon: '🏮',
            title: 'LOCAL EXPERTISE',
            desc: "Our guides have lived in Gion for years. We take you to bars, alleys, and viewpoints that aren't in any guidebook.",
          },
          {
            icon: '🍶',
            title: 'AUTHENTIC TASTINGS',
            desc: 'No tourist-trap sake. We pour what Kyoto residents actually drink, explained in plain English.',
          },
          {
            icon: '👥',
            title: 'SMALL GROUPS',
            desc: 'Max 8 guests means real conversation, flexible pacing, and a genuine experience — not a crowd.',
          },
        ].map(item => (
          <div class="text-center">
            <div class="dialogue-box inline-block mb-5 px-5 py-4">
              <span class="text-4xl">{item.icon}</span>
            </div>
            <h3 class="font-pixel text-[0.9rem] text-nes-amber mb-3">{item.title}</h3>
            <p class="font-sans text-gray-400 text-sm leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
