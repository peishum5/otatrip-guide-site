---
import BaseLayout from '../layouts/BaseLayout.astro';
import GroupCTA from '../components/GroupCTA.astro';
import ReviewsSection from '../components/ReviewsSection.astro';
import { getCollection } from 'astro:content';

const blogPosts = await getCollection('blog');
const latestPosts = blogPosts.slice(0, 3);

const stats = [
  { number: '200+', label: 'GUESTS GUIDED' },
  { number: '4.9', label: 'AVG RATING' },
  { number: '8', label: 'MAX PARTY SIZE' },
  { number: '2018', label: 'YEAR FOUNDED' },
];
---

<BaseLayout
  title="OTA Trip Guide — Kyoto Local Tours & Travel Guides"
  description="Explore Kyoto with local expert guides. Book the Gion Sake Walking Tour or browse our practical travel guides for first-time visitors."
>
  <!-- Hero Section -->
  <section class="scanlines bg-nes-black text-nes-white">
    <div class="relative z-10 max-w-6xl mx-auto px-4 py-20 md:py-32">
      <p class="font-pixel text-[0.45rem] text-nes-cyan mb-6 rpg-prefix">KYOTO LOCAL EXPERTS</p>
      <h1 class="font-pixel text-nes-amber leading-relaxed mb-6" style="font-size: clamp(0.9rem, 3vw, 1.5rem);">
        DISCOVER KYOTO<br />
        <span class="text-nes-white">LIKE A LOCAL</span>
      </h1>
      <p class="font-sans text-gray-300 text-lg leading-relaxed mb-8 max-w-xl pixel-cursor">
        Intimate evening walks through Gion's lantern-lit alleys. Premium sake tastings at bars only locals know.
        Small groups, big experiences.
      </p>
      <div class="flex flex-col sm:flex-row gap-5">
        <a href="/tours/gion-sake-walk" class="nes-btn nes-btn-gold">
          START GION SAKE WALK
        </a>
        <a href="/blog" class="nes-btn nes-btn-outline">
          BROWSE TRAVEL GUIDES
        </a>
      </div>
    </div>
  </section>

  <!-- Stats Bar — PLAYER STATS -->
  <section class="bg-nes-black border-y-2 border-nes-amber">
    <div class="max-w-6xl mx-auto px-4 py-8">
      <p class="font-pixel text-[0.4rem] text-nes-cyan text-center mb-6">-- PLAYER STATS --</p>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
        {stats.map(stat => (
          <div>
            <div class="nes-number text-2xl md:text-3xl mb-1">{stat.number}</div>
            <div class="font-pixel text-[0.35rem] text-gray-500 mt-1">{stat.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Tour Highlight Section -->
  <section class="max-w-6xl mx-auto px-4 py-16">
    <div class="grid md:grid-cols-2 gap-12 items-center">
      <div>
        <p class="font-pixel text-[0.4rem] text-nes-amber mb-4 rpg-prefix">SIGNATURE EXPERIENCE</p>
        <h2 class="font-pixel text-nes-white leading-relaxed mb-6" style="font-size: clamp(0.65rem, 2vw, 0.9rem);">
          GION SAKE<br />WALKING TOUR
        </h2>
        <p class="font-sans text-gray-300 leading-relaxed mb-6">
          Kyoto's most atmospheric neighborhood after dark. Three local sake bars, stone-paved alleys,
          lantern light, and stories from a guide who's lived it for years.
        </p>
        <ul class="space-y-3 mb-8">
          {[
            '3 premium sake tastings at curated local bars',
            "Walk Hanamikoji & Shinbashi — Gion's most iconic streets",
            'Max 8 guests for an intimate experience',
            'Light snacks included',
          ].map(item => (
            <li class="flex items-start gap-3 text-gray-300 text-sm font-sans">
              <span class="text-nes-green mt-0.5 shrink-0 font-pixel text-[0.4rem]">[OK]</span>
              {item}
            </li>
          ))}
        </ul>
        <div class="flex gap-4 flex-wrap">
          <a href="/tours/gion-sake-walk" class="nes-btn nes-btn-gold">
            TOUR DETAILS &amp; BOOK
          </a>
          <a href="/groups" class="nes-btn nes-btn-outline">
            GROUP INQUIRIES
          </a>
        </div>
      </div>

      <!-- Tour card — dialogue box -->
      <div class="dialogue-box">
        <p class="font-pixel text-[0.4rem] text-nes-cyan mb-4">// EVENING TOUR</p>
        <h3 class="font-pixel text-[0.6rem] text-nes-white mb-2 leading-relaxed">GION SAKE WALK</h3>
        <p class="font-pixel text-[0.35rem] text-gray-500 mb-6">3 HRS &middot; UP TO 8 GUESTS &middot; GION</p>
        <div class="space-y-3 text-sm font-sans">
          {[
            { label: 'MEETING POINT', value: 'Gion-Shijo St. Exit 6' },
            { label: 'START TIME', value: '17:30 or 18:00' },
            { label: 'LANGUAGE', value: 'English' },
            { label: 'INCLUDES', value: '3 sake tastings + snacks' },
          ].map(row => (
            <div class="flex justify-between border-b border-gray-800 pb-2">
              <span class="font-pixel text-[0.35rem] text-gray-500">{row.label}</span>
              <span class="text-gray-300 text-xs">{row.value}</span>
            </div>
          ))}
          <div class="flex justify-between">
            <span class="font-pixel text-[0.35rem] text-gray-500">RATING</span>
            <span class="font-pixel text-[0.4rem] text-nes-amber">4.9/5 ★★★★★</span>
          </div>
        </div>
        <a href="/tours/gion-sake-walk#booking" class="nes-btn nes-btn-gold block w-full text-center mt-8">
          CHECK AVAILABILITY
        </a>
      </div>
    </div>
  </section>

  <!-- B2B Group CTA -->
  <section class="max-w-6xl mx-auto px-4">
    <GroupCTA />
  </section>

  <!-- Latest Blog Posts -->
  <section class="max-w-6xl mx-auto px-4 py-16">
    <div class="flex items-end justify-between mb-8">
      <div>
        <p class="font-pixel text-[0.4rem] text-nes-amber mb-2 rpg-prefix">TRAVEL GUIDES</p>
        <h2 class="font-pixel text-[0.65rem] text-nes-white leading-relaxed">PLAN YOUR<br />KYOTO TRIP</h2>
      </div>
      <a href="/blog" class="font-pixel text-[0.4rem] text-nes-cyan hover:text-nes-amber transition-colors hidden md:block">
        ALL GUIDES &gt;
      </a>
    </div>

    {latestPosts.length > 0 ? (
      <div class="grid md:grid-cols-3 gap-6">
        {latestPosts.map(post => (
          <article class="border-2 border-gray-700 hover:border-nes-amber transition-colors group bg-nes-black">
            <a href={`/blog/${post.slug}`} class="block">
              <div class="bg-gray-900 border-b border-gray-700 h-36 flex items-end p-4">
                <span class="font-pixel text-[0.35rem] text-nes-amber">{post.data.category || 'KYOTO GUIDE'}</span>
              </div>
              <div class="p-5">
                <h3 class="font-pixel text-[0.4rem] text-nes-white group-hover:text-nes-amber transition-colors leading-relaxed mb-3 line-clamp-2">
                  {post.data.title}
                </h3>
                <p class="font-sans text-gray-500 text-sm leading-relaxed line-clamp-3">{post.data.description}</p>
                <div class="mt-4 font-pixel text-[0.35rem] text-nes-cyan">READ GUIDE &gt;</div>
              </div>
            </a>
          </article>
        ))}
      </div>
    ) : (
      <p class="font-pixel text-[0.45rem] text-gray-600 text-center py-12">// BLOG POSTS COMING SOON</p>
    )}

    <div class="text-center mt-8 md:hidden">
      <a href="/blog" class="font-pixel text-[0.4rem] text-nes-cyan hover:text-nes-amber transition-colors">
        VIEW ALL GUIDES &gt;
      </a>
    </div>
  </section>

  <!-- Reviews -->
  <section class="max-w-6xl mx-auto px-4">
    <ReviewsSection />
  </section>

  <!-- Why Choose Us -->
  <section class="bg-nes-black border-y-2 border-gray-800 py-16">
    <div class="max-w-6xl mx-auto px-4">
      <div class="text-center mb-12">
        <p class="font-pixel text-[0.4rem] text-nes-cyan mb-4 rpg-prefix">WHY OTA TRIP GUIDE</p>
        <h2 class="font-pixel text-nes-white leading-relaxed" style="font-size: clamp(0.65rem, 2vw, 0.9rem);">
          KYOTO FROM<br />THE INSIDE
        </h2>
      </div>
      <div class="grid md:grid-cols-3 gap-8">
        {[
          {
            icon: '🏮',
            title: 'LOCAL EXPERTISE',
            desc: "Our guides have lived in Gion for years. We take you to bars, alleys, and viewpoints that aren't in any guidebook.",
          },
          {
            icon: '🍶',
            title: 'AUTHENTIC TASTINGS',
            desc: 'No tourist-trap sake. We pour what Kyoto residents actually drink, explained in plain English.',
          },
          {
            icon: '👥',
            title: 'SMALL GROUPS',
            desc: 'Max 8 guests means real conversation, flexible pacing, and a genuine experience — not a crowd.',
          },
        ].map(item => (
          <div class="text-center">
            <div class="dialogue-box inline-block mb-5 px-5 py-4">
              <span class="text-4xl">{item.icon}</span>
            </div>
            <h3 class="font-pixel text-[0.5rem] text-nes-amber mb-3">{item.title}</h3>
            <p class="font-sans text-gray-400 text-sm leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
