---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Message Sent | OTAtrip Guide" noIndex={true}>
  <div class="max-w-2xl mx-auto px-4 py-24 text-center">
    <div class="dialogue-box inline-block mb-8 px-8 py-6">
      <div class="text-5xl mb-4">🍶</div>
      <h1 class="font-pixel text-nes-white leading-relaxed" style="font-size: clamp(0.7rem, 2vw, 1rem);">MESSAGE RECEIVED!</h1>
    </div>
    <p class="font-sans text-gray-300 text-lg mb-2">Thank you for reaching out.</p>
    <p class="font-sans text-gray-500 text-sm mb-10">We'll reply to your inquiry within 24 hours.</p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a href="/" class="nes-btn nes-btn-gold">Back to Home</a>
      <a href="/tours" class="nes-btn nes-btn-outline">Browse Tours</a>
    </div>
  </div>
</BaseLayout>
