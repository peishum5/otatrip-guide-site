---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BookingWidget from '../../components/BookingWidget.astro';
import GroupCTA from '../../components/GroupCTA.astro';
import ReviewsSection from '../../components/ReviewsSection.astro';

const highlights = [
  'Walking tour with a guide around Shimogamo Shrine',
  'Your original short manga — you as the main character',
  'Digital data: high-resolution files for your social media',
];

const itinerary = [
  {
    stop: '01',
    name: 'Kamogawa River',
    desc: 'The Kamo River runs through the heart of Kyoto — a scenic and tranquil waterway lined with cherry blossom trees and rich in history. We start here for photos and an intro to the area.',
    duration: null,
  },
  {
    stop: '02',
    name: 'Kamogawa Delta',
    desc: 'Where the Kamo and Takano Rivers meet. Famous for its stepping stones ("tobiishi") — a beloved spot that appears in countless Japanese animations. Jump across and get the shot.',
    duration: '15 min',
  },
  {
    stop: '03',
    name: 'Demachi Masugata Shopping Street',
    desc: 'A charming covered arcade in the Demachi area. Nostalgic atmosphere, local sweets, and fresh produce. A slice of everyday Kyoto life most tourists never see.',
    duration: '10 min',
  },
  {
    stop: '04',
    name: 'Tadasu-no-Mori Grove',
    desc: 'A sacred woodland within the Shimogamo Shrine grounds — roughly 12 hectares of ancient forest that has remained largely untouched for centuries. One of the most atmospheric spots in Kyoto.',
    duration: '15 min',
  },
  {
    stop: '05',
    name: 'Shimogamo Jinja',
    desc: 'One of Kyoto\'s oldest Shinto shrines, dating to the 6th century. Located at the confluence of the Kamo and Takano Rivers and listed as a UNESCO World Heritage Site. We finish with photos inside the shrine grounds.',
    duration: '20 min',
  },
];

const notes = [
  'Confirmation will be received at time of booking',
  'Not recommended for travelers with back problems',
  'No heart problems or other serious medical conditions',
  'Not wheelchair accessible',
  'Travelers should have a moderate physical fitness level',
  'This tour involves a lot of walking — please wear comfortable clothing and shoes',
];

const faqs = [
  {
    q: 'What is the manga souvenir?',
    a: 'We capture cinematic photos of you throughout the walk, then create a custom manga-style page featuring you as the main character. You receive a physical print plus high-resolution digital files.',
  },
  {
    q: 'When do I receive my manga?',
    a: 'The physical manga print and digital files are delivered after the tour. Exact timing confirmed at booking.',
  },
  {
    q: 'What are the tour start times?',
    a: 'Two slots available: 10:00 and 14:00. Select your preferred time when booking.',
  },
  {
    q: 'How much walking is involved?',
    a: 'The route covers several km on mostly flat paths — through the forest, along the river, and inside the shrine. Comfortable shoes are essential.',
  },
  {
    q: 'Is this suitable for children?',
    a: 'Yes, families are very welcome. The pace is relaxed and the route is enjoyable for all ages. Not recommended for travelers with back problems or serious medical conditions.',
  },
];
---

<BaseLayout
  title="Shimogamo Shrine & Manga Walk — Kyoto Morning Tour | OTAtrip Guide"
  description="A morning walk through Shimogamo Shrine and Tadasu-no-Mori forest. Cinematic photography throughout, finishing with a custom manga-style print souvenir."
  canonical="/tours/shimogamo-manga-walk"
>
  <Fragment slot="head">
    <script is:inline type="text/javascript" src="https://widgets.bokun.io/assets/javascripts/apps/build/BokunWidgetsLoader.js?bookingChannelUUID=f23bdb2c-1b09-450d-bc03-a0a0b23700e9" async></script>
  </Fragment>

  <!-- Hero -->
  <section class="relative bg-nes-black overflow-hidden">
    <img
      src="/images/tours/shimogamo/photo-bridge.jpg"
      alt="Guests at Shimogamo Shrine red bridge"
      class="absolute inset-0 w-full h-full object-cover opacity-60"
      loading="eager"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-nes-black via-nes-black/60 to-transparent"></div>
    <div class="relative z-10 max-w-4xl mx-auto px-4 py-24 md:py-32">
      <p class="font-pixel text-[0.9rem] text-nes-amber mb-4 rpg-prefix">WALKING TOUR · SHIMOGAMO & KAMOGAWA</p>
      <h1 class="font-sans text-3xl md:text-4xl font-bold text-nes-white leading-tight mb-4">
        Shimogamo Shrine &amp; Manga Walk
      </h1>
      <p class="font-sans text-gray-300 text-base leading-relaxed mb-8 max-w-xl">
        Explore the hidden gems of Kyoto on this engaging walking tour of the mystical Shimogamo Shrine
        and the iconic Kamogawa Delta — complete with a personalized manga-style souvenir featuring you as the main character.
      </p>
      <div class="flex flex-wrap gap-6 font-pixel text-[0.9rem] mb-8">
        {[
          { label: 'Duration', value: '~2 hours' },
          { label: 'Start times', value: '10:00 / 14:00' },
          { label: 'Language', value: 'English' },
          { label: 'All ages', value: 'Welcome' },
        ].map(item => (
          <div>
            <div class="font-pixel text-[0.9rem] text-nes-amber">{item.value}</div>
            <div class="font-pixel text-[0.9rem] text-gray-500">{item.label}</div>
          </div>
        ))}
      </div>
      <a href="#booking" class="nes-btn nes-btn-gold">BOOK YOUR SPOT</a>
    </div>
  </section>

  <div class="max-w-4xl mx-auto px-4 py-12">

    <!-- Highlights -->
    <section class="mb-12">
      <div class="flex items-center gap-4 mb-6">
        <h2 class="font-pixel text-[0.9rem] text-nes-amber">WHAT'S INCLUDED</h2>
        <div class="flex-1 border-t border-gray-800"></div>
      </div>
      <div class="grid md:grid-cols-2 gap-3">
        {highlights.map(item => (
          <div class="flex items-start gap-3 bg-gray-900 border border-gray-800 px-4 py-3">
            <span class="font-pixel text-[0.9rem] text-nes-green shrink-0">[OK]</span>
            <span class="font-sans text-gray-300 text-sm leading-relaxed">{item}</span>
          </div>
        ))}
      </div>
    </section>

    <!-- Tour Photos -->
    <section class="mb-12">
      <div class="flex items-center gap-4 mb-6">
        <h2 class="font-pixel text-[0.9rem] text-nes-amber">TOUR PHOTOS</h2>
        <div class="flex-1 border-t border-gray-800"></div>
      </div>
      <div class="grid grid-cols-3 gap-2 mb-2">
        <div class="overflow-hidden border border-gray-800">
          <img src="/images/tours/shimogamo/photo-bridge.jpg" alt="Guests at Shimogamo Shrine red bridge" class="w-full h-48 object-cover" loading="lazy" />
        </div>
        <div class="overflow-hidden border border-gray-800">
          <img src="/images/tours/shimogamo/photo-delta.jpg" alt="Guests on stepping stones at Kamogawa Delta" class="w-full h-48 object-cover" loading="lazy" />
        </div>
        <div class="overflow-hidden border border-gray-800">
          <img src="/images/tours/shimogamo/photo-shrine.jpg" alt="Guests bowing at Shimogamo Shrine" class="w-full h-48 object-cover" loading="lazy" />
        </div>
      </div>
    </section>

    <!-- Manga Sample -->
    <section class="mb-12">
      <div class="flex items-center gap-4 mb-3">
        <h2 class="font-pixel text-[0.9rem] text-nes-amber">YOUR MANGA SOUVENIR</h2>
        <div class="flex-1 border-t border-gray-800"></div>
      </div>
      <p class="font-sans text-sm text-gray-400 leading-relaxed mb-6">
        After the walk, we turn your best shots into a manga-style artwork — your Kyoto moment, illustrated.
        Here are some examples from past tours.
      </p>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-2">
        {[
          { src: '/images/tours/shimogamo/manga-1.jpg', alt: 'Manga sample — Shimogamo shrine and river' },
          { src: '/images/tours/shimogamo/manga-2.jpg', alt: 'Manga sample — forest walk and shrine gate' },
          { src: '/images/tours/shimogamo/manga-3.jpg', alt: 'Manga sample — shrine interior and water' },
          { src: '/images/tours/shimogamo/manga-4.jpg', alt: 'Manga sample — Tadasu-no-Mori and delta' },
        ].map(photo => (
          <div class="overflow-hidden border border-gray-800">
            <img src={photo.src} alt={photo.alt} class="w-full object-cover" loading="lazy" />
          </div>
        ))}
      </div>
    </section>

    <!-- Itinerary -->
    <section class="mb-12">
      <div class="flex items-center gap-4 mb-6">
        <h2 class="font-pixel text-[0.9rem] text-nes-amber">ITINERARY</h2>
        <div class="flex-1 border-t border-gray-800"></div>
      </div>
      <div class="space-y-5">
        {itinerary.map(item => (
          <div class="flex items-start gap-5">
            <span class="font-pixel text-[0.9rem] text-nes-cyan shrink-0 w-8 text-right pt-1">{item.stop}</span>
            <div class="flex-1 border-l border-gray-700 pl-5 pb-3">
              <p class="font-pixel text-[0.9rem] text-nes-white mb-2">{item.name.toUpperCase()}</p>
              <p class="font-sans text-sm text-gray-300 leading-relaxed mb-1">{item.desc}</p>
              {item.duration && <p class="font-pixel text-[0.9rem] text-gray-600">{item.duration} · Admission Free</p>}
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Meeting point -->
    <section class="mb-12">
      <div class="dialogue-box">
        <p class="font-pixel text-[0.9rem] text-nes-cyan mb-4">// MEETING POINT</p>
        <div class="grid md:grid-cols-2 gap-6">
          <div>
            <p class="font-pixel text-[0.9rem] text-nes-white mb-1">Kamogawa Delta (Demachiyanagi)</p>
            <p class="font-sans text-gray-400 text-xs leading-relaxed">
              Near Demachiyanagi Station (Keihan / Eizan Line)<br />
              Exact meeting spot confirmed upon booking.
            </p>
            <p class="font-sans text-gray-600 text-xs mt-3">
              Please arrive 5 minutes early. Your guide will be waiting at the meeting point.
            </p>
          </div>
          <div class="space-y-2 font-pixel text-[0.9rem]">
            {[
              { k: 'Morning slot', v: '10:00 start' },
              { k: 'Afternoon slot', v: '14:00 start' },
              { k: 'Duration', v: '~2 hours' },
              { k: 'Shoes', v: 'Comfortable' },
            ].map(row => (
              <div class="flex justify-between border-b border-gray-800 pb-2">
                <span class="text-gray-500">{row.k}</span>
                <span class="text-nes-white">{row.v}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- Additional info -->
    <section class="mb-12">
      <div class="flex items-center gap-4 mb-6">
        <h2 class="font-pixel text-[0.9rem] text-nes-amber">ADDITIONAL INFO</h2>
        <div class="flex-1 border-t border-gray-800"></div>
      </div>
      <div class="grid md:grid-cols-2 gap-3">
        {notes.map(note => (
          <div class="flex items-start gap-3 bg-gray-900 border border-gray-800 px-4 py-3">
            <span class="font-pixel text-[0.9rem] text-nes-amber shrink-0">!</span>
            <span class="font-sans text-gray-400 text-sm leading-relaxed">{note}</span>
          </div>
        ))}
      </div>
    </section>

    <!-- Booking -->
    <section id="booking" class="mb-12">
      <div class="flex items-center gap-4 mb-6">
        <h2 class="font-pixel text-[0.9rem] text-nes-amber">BOOK YOUR SPOT</h2>
        <div class="flex-1 border-t border-gray-800"></div>
      </div>
      <p class="font-sans text-gray-500 text-sm mb-6">Spots are limited. Book early to secure your date.</p>
      <BookingWidget widgetPath="experience-calendar/901511" />
    </section>

    <!-- Reviews -->
    <ReviewsSection />

    <!-- Group CTA -->
    <GroupCTA />

    <!-- FAQ -->
    <section class="mb-12">
      <div class="flex items-center gap-4 mb-6">
        <h2 class="font-pixel text-[0.9rem] text-nes-amber">FAQ</h2>
        <div class="flex-1 border-t border-gray-800"></div>
      </div>
      <div class="space-y-3">
        {faqs.map(faq => (
          <details class="border border-gray-800 bg-gray-900 group">
            <summary class="flex items-center justify-between px-5 py-4 cursor-pointer font-pixel text-[0.9rem] text-nes-white hover:text-nes-amber transition-colors">
              {faq.q}
              <span class="ml-4 text-gray-600 shrink-0 group-open:rotate-180 transition-transform">▼</span>
            </summary>
            <div class="px-5 pb-4 font-sans text-sm text-gray-400 leading-relaxed border-t border-gray-800 pt-4">
              {faq.a}
            </div>
          </details>
        ))}
      </div>
    </section>

  </div>

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "TouristAttraction",
    "name": "Shimogamo Shrine & Manga Walk",
    "description": "A morning walk through Shimogamo Shrine and Tadasu-no-Mori forest with cinematic photography and a custom manga-style print souvenir.",
    "url": "https://otatrip-guide.com/tours/shimogamo-manga-walk",
    "provider": {
      "@type": "TouristInformationCenter",
      "name": "OTAtrip Guide",
      "url": "https://otatrip-guide.com"
    },
    "offers": {
      "@type": "Offer",
      "availability": "https://schema.org/InStock"
    }
  })} />
</BaseLayout>
