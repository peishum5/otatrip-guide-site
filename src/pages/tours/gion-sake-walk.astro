---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BookingWidget from '../../components/BookingWidget.astro';
import GroupCTA from '../../components/GroupCTA.astro';
import ReviewsSection from '../../components/ReviewsSection.astro';

const highlights = [
  'Visit 3 hand-picked sake bars in Gion — places locals actually go',
  'Learn to distinguish Fushimi-style sake from other regions',
  'Walk the lantern-lit alleys of Hanamikoji and Shinbashi',
  'Hear stories of geiko, maiko, and the traditional entertainment district',
  'Small groups (max 10 guests) for an intimate, unhurried experience',
  'Light snacks included at each stop',
];

const timeline = [
  { time: 'START', desc: 'Meet at Shijo Kiyamachi. Your guide is holding an "Otatrip Guide" sign. Brief intro and neighborhood overview.' },
  { time: '+15\'', desc: 'First sake bar — learn the basics of Fushimi sake style and taste two varieties.' },
  { time: '+30\'', desc: 'Walk Hanamikoji and Shinbashi — the iconic stone-paved streets of old Gion.' },
  { time: '+50\'', desc: 'Second sake bar — compare regional sake styles, with local snack pairings.' },
  { time: '+65\'', desc: 'Hidden alley walk through Gion Shimbashi designated townscape.' },
  { time: '+75\'', desc: 'Third sake bar — premium junmai selection. Open Q&A with your guide.' },
  { time: '+90\'', desc: 'Tour ends. Optional: continue exploring Gion on your own.' },
];

const faqs = [
  {
    q: 'Do I need to know anything about sake beforehand?',
    a: 'No experience needed. The guide explains everything from scratch — what sake is, how it\'s made in Kyoto, and how to taste it. Total beginners are welcome.',
  },
  {
    q: 'Is this suitable for non-drinkers?',
    a: 'The tour focuses on sake culture and the Gion neighborhood experience. Non-drinkers can participate and sip at their own pace; we always have non-alcoholic options available.',
  },
  {
    q: 'How much walking is involved?',
    a: 'About 2–3 km in total on stone-paved streets. Comfortable flat shoes recommended. The pace is relaxed with frequent stops.',
  },
  {
    q: 'What if it rains?',
    a: 'The tour runs rain or shine — Gion is beautiful in the rain. Bring an umbrella or purchase a compact one at a nearby konbini.',
  },
  {
    q: 'Can I book for a private group?',
    a: 'Yes. Private bookings are available for groups of 2–8. Contact us via the Groups page.',
  },
];

const photos = [
  { src: '/images/tours/gion/yasaka-night.jpg',   alt: 'Yasaka Pagoda lit up at night, Gion' },
  { src: '/images/tours/gion/maiko-pagoda.jpg',   alt: 'Maiko in front of Yasaka Pagoda' },
  { src: '/images/tours/tour-yasaka-gate.jpg',    alt: 'Group at Yasaka Shrine gate at night' },
  { src: '/images/tours/gion/maiko-alley.jpg',    alt: 'Maiko walking through a Gion alley' },
  { src: '/images/tours/tour-sake-pour.jpg',      alt: 'Sake being poured at a local bar' },
  { src: '/images/tours/tour-gion-walk.jpg',      alt: 'Walking through Gion under lantern light' },
  { src: '/images/tours/gion/maiko-walk-1.jpg',   alt: 'Maiko walking in Gion' },
  { src: '/images/tours/tour-sake-toast.jpg',     alt: 'Guests toasting with sake shots' },
  { src: '/images/tours/tour-alley-group.jpg',    alt: 'Guide explaining in a Gion alley' },
  { src: '/images/tours/gion/maiko-walk-2.jpg',   alt: 'Maiko in colorful kimonos, Gion' },
  { src: '/images/tours/tour-guide.jpg',          alt: 'Local guide pointing out Kyoto landmarks' },
  { src: '/images/tours/tour-shrine-stone.jpg',   alt: 'Guest at Yasaka Shrine stone tunnel' },
  { src: '/images/tours/tour-night-city.jpg',     alt: 'Group walking through Kyoto at night' },
  { src: '/images/tours/tour-kiyomizu-night.jpg', alt: 'Kiyomizu-dera pagoda at night' },
];
---

<BaseLayout
  title="Gion Sake Walking Tour — Kyoto Experience | OTAtrip Guide"
  description="A 90-minute walk through Gion's iconic stone-paved alleys with sake tastings at 3 local bars. 4 daily slots: 15:30 / 17:30 / 19:30 / 21:30. Small groups, max 10 guests. Rated 4.9/5."
  canonical="/tours/gion-sake-walk"
  ogImage="/images/tours/gion/hero.jpg"
>
  <Fragment slot="head">
    <script is:inline type="text/javascript" src="https://widgets.bokun.io/assets/javascripts/apps/build/BokunWidgetsLoader.js?bookingChannelUUID=f23bdb2c-1b09-450d-bc03-a0a0b23700e9" async></script>
  </Fragment>

  <!-- Hero -->
  <section class="relative bg-nes-black overflow-hidden">
    <img
      src="/images/tours/gion/hero.jpg"
      alt="Tour guests laughing together in Gion at night"
      class="absolute inset-0 w-full h-full object-cover opacity-60"
      loading="eager"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-nes-black via-nes-black/60 to-transparent"></div>
    <div class="relative z-10 max-w-4xl mx-auto px-4 py-24 md:py-32">
      <p class="font-pixel text-[0.9rem] text-nes-amber mb-4 rpg-prefix">WALKING TOUR · GION DISTRICT</p>
      <h1 class="font-sans text-3xl md:text-4xl font-bold text-nes-white leading-tight mb-4">
        Gion Sake Walking Tour
      </h1>
      <p class="font-sans text-gray-300 text-base leading-relaxed mb-8 max-w-xl">
        Walk the stone-paved alleys of Kyoto's most iconic neighborhood.
        Three local sake bars. Stories from a guide who calls Gion home.
      </p>
      <div class="flex flex-wrap gap-6 font-pixel text-[0.9rem] mb-8">
        {[
          { label: 'Duration', value: '90 min' },
          { label: 'Group size', value: 'Max 10' },
          { label: 'Language', value: 'English' },
          { label: 'Rating', value: '★ 4.9 / 5' },
        ].map(item => (
          <div>
            <div class="font-pixel text-[0.9rem] text-nes-amber">{item.value}</div>
            <div class="font-pixel text-[0.9rem] text-gray-500">{item.label}</div>
          </div>
        ))}
      </div>
      <a href="#booking" class="nes-btn nes-btn-gold">BOOK YOUR SPOT</a>
    </div>
  </section>

  <div class="max-w-4xl mx-auto px-4 py-12">

    <!-- Highlights -->
    <section class="mb-12">
      <div class="flex items-center gap-4 mb-6">
        <h2 class="font-pixel text-[0.9rem] text-nes-amber">WHAT'S INCLUDED</h2>
        <div class="flex-1 border-t border-gray-800"></div>
      </div>
      <div class="grid md:grid-cols-2 gap-3">
        {highlights.map(item => (
          <div class="flex items-start gap-3 bg-gray-900 border border-gray-800 px-4 py-3">
            <span class="font-pixel text-[0.9rem] text-nes-green shrink-0">[OK]</span>
            <span class="font-sans text-gray-300 text-sm leading-relaxed">{item}</span>
          </div>
        ))}
      </div>
    </section>

    <!-- Photo gallery -->
    <section class="mb-12">
      <div class="flex items-center gap-4 mb-6">
        <h2 class="font-pixel text-[0.9rem] text-nes-amber">TOUR PHOTOS</h2>
        <div class="flex-1 border-t border-gray-800"></div>
      </div>
      <div class="columns-2 md:columns-3 gap-2 space-y-2">
        {photos.map(photo => (
          <div class="break-inside-avoid overflow-hidden border border-gray-800">
            <img
              src={photo.src}
              alt={photo.alt}
              class="w-full object-cover"
              loading="lazy"
            />
          </div>
        ))}
      </div>
    </section>

    <!-- Timeline -->
    <section class="mb-12">
      <div class="flex items-center gap-4 mb-6">
        <h2 class="font-pixel text-[0.9rem] text-nes-amber">TOUR TIMELINE</h2>
        <div class="flex-1 border-t border-gray-800"></div>
      </div>
      <div class="space-y-5">
        {timeline.map(item => (
          <div class="flex items-start gap-5">
            <span class="font-pixel text-[0.9rem] text-nes-cyan shrink-0 w-12 text-right pt-1">{item.time}</span>
            <div class="flex-1 border-l border-gray-700 pl-5 pb-3">
              <p class="font-sans text-sm text-gray-300 leading-relaxed">{item.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Meeting point -->
    <section class="mb-12">
      <div class="dialogue-box">
        <p class="font-pixel text-[0.9rem] text-nes-cyan mb-4">// MEETING POINT</p>
        <div class="grid md:grid-cols-2 gap-6">
          <div>
            <p class="font-sans text-nes-white font-semibold text-sm mb-1">Shijo Kiyamachi</p>
            <p class="font-sans text-gray-400 text-xs leading-relaxed mb-3">
              On Kiyamachi Street, slightly south of Shijo — between McDonald's and the Japanese restaurant Kikunoi Roan.
              Your guide will be holding a sign that reads <span class="text-nes-white">"Otatrip Guide"</span>.
            </p>
            <p class="font-sans text-gray-600 text-xs mb-3">
              This is a group tour. Please arrive a few minutes early — late arrivals may cause the tour to start without you.
            </p>
            <a
              href="https://maps.app.goo.gl/J7SmSwzVmAfjZJs36"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 font-pixel text-[0.9rem] text-nes-cyan hover:text-nes-amber transition-colors"
            >
              ▶ OPEN IN GOOGLE MAPS
            </a>
          </div>
          <div class="space-y-2 font-pixel text-[0.9rem]">
            {[
              { k: 'Start times', v: '15:30 / 17:30 / 19:30 / 21:30' },
              { k: 'Duration', v: '90 min' },
            ].map(row => (
              <div class="flex justify-between border-b border-gray-800 pb-2">
                <span class="text-gray-500">{row.k}</span>
                <span class="text-nes-white">{row.v}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- Booking -->
    <section id="booking" class="mb-12">
      <div class="flex items-center gap-4 mb-6">
        <h2 class="font-pixel text-[0.9rem] text-nes-amber">BOOK YOUR SPOT</h2>
        <div class="flex-1 border-t border-gray-800"></div>
      </div>
      <p class="font-sans text-gray-500 text-sm mb-6">Tours fill quickly, especially on weekends.</p>
      <BookingWidget widgetPath="experience-calendar/901507" />
    </section>

    <!-- Reviews -->
    <ReviewsSection />

    <!-- Group CTA -->
    <GroupCTA />

    <!-- FAQ -->
    <section class="mb-12">
      <div class="flex items-center gap-4 mb-6">
        <h2 class="font-pixel text-[0.9rem] text-nes-amber">FAQ</h2>
        <div class="flex-1 border-t border-gray-800"></div>
      </div>
      <div class="space-y-3">
        {faqs.map(faq => (
          <details class="border border-gray-800 bg-gray-900 group">
            <summary class="flex items-center justify-between px-5 py-4 cursor-pointer font-pixel text-[0.9rem] text-nes-white hover:text-nes-amber transition-colors">
              {faq.q}
              <span class="ml-4 text-gray-600 shrink-0 group-open:rotate-180 transition-transform">▼</span>
            </summary>
            <div class="px-5 pb-4 font-sans text-sm text-gray-400 leading-relaxed border-t border-gray-800 pt-4">
              {faq.a}
            </div>
          </details>
        ))}
      </div>
    </section>

  </div>

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "TouristAttraction",
    "name": "Gion Sake Walking Tour",
    "description": "A 90-minute walking tour through Gion's stone-paved alleys with sake tastings at 3 local bars. 4 daily slots. Small groups of max 10 guests.",
    "url": "https://otatrip-guide.com/tours/gion-sake-walk",
    "provider": {
      "@type": "TouristInformationCenter",
      "name": "OTAtrip Guide",
      "url": "https://otatrip-guide.com"
    },
    "offers": {
      "@type": "Offer",
      "availability": "https://schema.org/InStock"
    },
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "4.9",
      "reviewCount": "200"
    }
  })} />
</BaseLayout>
