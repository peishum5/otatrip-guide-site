---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BookingWidget from '../../components/BookingWidget.astro';
import GroupCTA from '../../components/GroupCTA.astro';
import ReviewsSection from '../../components/ReviewsSection.astro';

const highlights = [
  'Visit 3 hand-picked sake bars in Gion — places locals actually go',
  'Learn to distinguish Fushimi-style sake from other regions',
  'Walk the lantern-lit alleys of Hanamikoji and Shinbashi',
  'Hear stories of geiko, maiko, and the traditional entertainment district',
  'Small groups (max 8 guests) for an intimate, unhurried experience',
  'Light snacks included at each stop',
];

const timeline = [
  { time: '17:30', desc: 'Meet at Gion-Shijo Station, Exit 6. Brief intro and neighborhood overview.' },
  { time: '17:45', desc: 'First sake bar — learn the basics of Fushimi sake style and taste two varieties.' },
  { time: '18:30', desc: 'Walk Hanamikoji and Shinbashi — the iconic lantern-lit streets of old Gion.' },
  { time: '19:00', desc: 'Second sake bar — compare regional sake styles, with local snack pairings.' },
  { time: '19:45', desc: 'Hidden alley walk through Gion Shimbashi designated townscape.' },
  { time: '20:00', desc: 'Third sake bar — premium junmai selection. Open Q&A with your guide.' },
  { time: '20:30', desc: 'Tour ends near Gion-Shijo Station. Optional: continue exploring on your own.' },
];

const faqs = [
  {
    q: 'Do I need to know anything about sake beforehand?',
    a: 'No experience needed. The guide explains everything from scratch — what sake is, how it\'s made in Kyoto, and how to taste it. Total beginners are welcome.',
  },
  {
    q: 'Is this suitable for non-drinkers?',
    a: 'The tour focuses on sake culture and the Gion neighborhood experience. Non-drinkers can participate and sip at their own pace; we always have non-alcoholic options available.',
  },
  {
    q: 'How much walking is involved?',
    a: 'About 2–3 km in total on stone-paved streets. Comfortable flat shoes recommended. The pace is relaxed with frequent stops.',
  },
  {
    q: 'What if it rains?',
    a: 'The tour runs rain or shine — Gion is beautiful in the rain. Bring an umbrella or purchase a compact one at a nearby konbini.',
  },
  {
    q: 'Can I book for a private group?',
    a: 'Yes. Private bookings are available for groups of 2–8 (and larger for corporate or agency bookings). Contact us via the Groups page.',
  },
];
---

<BaseLayout
  title="Gion Sake Walking Tour — Kyoto Evening Experience | OTA Trip Guide"
  description="An intimate 3-hour evening walk through Gion's lantern-lit alleys with sake tastings at 3 local bars. Small groups of max 8 guests. Kyoto local expert guides."
  canonical="/tours/gion-sake-walk"
>
  <Fragment slot="head">
    <script is:inline type="text/javascript" src="https://widgets.bokun.io/assets/javascripts/apps/build/BokunWidgetsLoader.js?bookingChannelUUID=f23bdb2c-1b09-450d-bc03-a0a0b23700e9" async></script>
  </Fragment>

  <!-- Hero -->
  <section class="bg-navy-dark text-white py-16 md:py-24">
    <div class="max-w-4xl mx-auto px-4">
      <div class="text-gold text-xs font-bold uppercase tracking-widest mb-4">Evening Tour &middot; Gion District</div>
      <h1 class="text-4xl md:text-5xl font-bold leading-tight mb-6">
        Gion Sake Walking Tour
      </h1>
      <p class="text-gray-300 text-xl leading-relaxed mb-8 max-w-2xl">
        Walk the stone-paved alleys of Kyoto's most iconic neighborhood after dark.
        Three local sake bars. Lantern light. Stories from a guide who calls Gion home.
      </p>

      <!-- Quick facts -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 bg-navy/60 rounded-xl p-6">
        {[
          { label: 'Duration', value: '3 hours' },
          { label: 'Group size', value: 'Max 8 guests' },
          { label: 'Language', value: 'English' },
          { label: 'Rating', value: '4.9 / 5' },
        ].map(item => (
          <div class="text-center">
            <div class="text-gold font-bold text-lg">{item.value}</div>
            <div class="text-gray-400 text-xs mt-0.5">{item.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <div class="max-w-4xl mx-auto px-4 py-12">

    <!-- Highlights -->
    <section class="mb-12">
      <h2 class="text-2xl font-bold text-navy-dark mb-6">What's Included</h2>
      <div class="grid md:grid-cols-2 gap-3">
        {highlights.map(item => (
          <div class="flex items-start gap-3 bg-gray-50 rounded-lg px-4 py-3">
            <span class="text-gold shrink-0 mt-0.5">✓</span>
            <span class="text-gray-700 text-sm">{item}</span>
          </div>
        ))}
      </div>
    </section>

    <!-- Tour timeline -->
    <section class="mb-12">
      <h2 class="text-2xl font-bold text-navy-dark mb-6">Tour Timeline</h2>
      <div class="relative">
        <div class="absolute left-16 top-0 bottom-0 w-px bg-gray-200"></div>
        <div class="space-y-6">
          {timeline.map(item => (
            <div class="flex items-start gap-6">
              <div class="w-14 shrink-0 text-right">
                <span class="text-gold font-bold text-sm">{item.time}</span>
              </div>
              <div class="relative flex items-start gap-4 pb-2">
                <div class="w-3 h-3 rounded-full bg-gold shrink-0 mt-1 z-10"></div>
                <p class="text-gray-700 text-sm leading-relaxed">{item.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Meeting point -->
    <section class="mb-12 bg-navy-dark text-white rounded-xl p-6">
      <h2 class="text-xl font-bold mb-4 text-gold">Meeting Point</h2>
      <div class="grid md:grid-cols-2 gap-6">
        <div>
          <p class="text-gray-300 text-sm leading-relaxed mb-3">
            <strong class="text-white">Gion-Shijo Station, Exit 6</strong><br />
            Keihan Line, Gion-Shijo Station<br />
            Gion-cho, Higashiyama-ku, Kyoto
          </p>
          <p class="text-gray-400 text-xs">
            Look for your guide holding a small OTA Trip Guide sign near the exit. Please arrive 5 minutes early.
          </p>
        </div>
        <div class="bg-navy rounded-lg p-4 text-sm">
          <div class="font-medium text-gold mb-3">Practical Info</div>
          <div class="space-y-2 text-gray-300">
            <div class="flex justify-between"><span>Start time</span><span>17:30</span></div>
            <div class="flex justify-between"><span>End time</span><span>~20:30</span></div>
            <div class="flex justify-between"><span>Dress code</span><span>Casual (comfortable shoes)</span></div>
            <div class="flex justify-between"><span>Min. age</span><span>18+ (alcohol tour)</span></div>
          </div>
        </div>
      </div>
    </section>

    <!-- Booking Widget -->
    <section id="booking" class="mb-12">
      <h2 class="text-2xl font-bold text-navy-dark mb-2">Book Your Spot</h2>
      <p class="text-gray-500 text-sm mb-6">Tours fill quickly, especially on weekends. Secure your place below.</p>
      <BookingWidget widgetPath="experience/901507" />
    </section>

    <!-- Reviews -->
    <ReviewsSection />

    <!-- Group CTA -->
    <GroupCTA />

    <!-- FAQ -->
    <section class="mb-12">
      <h2 class="text-2xl font-bold text-navy-dark mb-6">Frequently Asked Questions</h2>
      <div class="space-y-4">
        {faqs.map(faq => (
          <details class="border border-gray-200 rounded-lg overflow-hidden group">
            <summary class="flex items-center justify-between px-6 py-4 cursor-pointer font-medium text-navy-dark hover:text-gold transition-colors">
              {faq.q}
              <span class="ml-4 text-gray-400 group-open:rotate-180 transition-transform shrink-0">&#9660;</span>
            </summary>
            <div class="px-6 pb-5 text-gray-600 text-sm leading-relaxed border-t border-gray-100 pt-4">
              {faq.a}
            </div>
          </details>
        ))}
      </div>
    </section>

    <!-- Schema JSON-LD -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "TouristAttraction",
      "name": "Gion Sake Walking Tour",
      "description": "An intimate 3-hour evening walking tour through Gion with sake tastings at 3 local bars. Small groups of max 8 guests.",
      "url": "https://otatrip-guide.com/tours/gion-sake-walk",
      "provider": {
        "@type": "TouristInformationCenter",
        "name": "OTA Trip Guide",
        "url": "https://otatrip-guide.com"
      },
      "offers": {
        "@type": "Offer",
        "availability": "https://schema.org/InStock"
      },
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "4.9",
        "reviewCount": "200"
      }
    })} />
  </div>
</BaseLayout>
