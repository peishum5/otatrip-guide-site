---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');

const getSortDate = (post: (typeof allPosts)[number]) => {
  const raw = post.data.last_updated || post.data.pubDate || '1970-01-01';
  return Number.isNaN(Date.parse(raw)) ? 0 : Date.parse(raw);
};

const inferCategory = (post: (typeof allPosts)[number]) => {
  if (post.data.category) return post.data.category;
  if (post.slug.startsWith('plan/')) return 'Planning Basics';
  if (post.slug.startsWith('itineraries/')) return 'Itineraries';
  return 'More Guides';
};

const categoryOrder = [
  'Planning Basics',
  'Itineraries',
  'Sights',
  'Neighborhoods',
  'Food & Drink',
  'Culture',
  'Day Trips',
  'Seasonal',
  'More Guides',
];

const groupedPosts = allPosts
  .slice()
  .sort((a, b) => getSortDate(b) - getSortDate(a))
  .reduce<Record<string, typeof allPosts>>((acc, post) => {
    const category = inferCategory(post);
    if (!acc[category]) acc[category] = [];
    acc[category].push(post);
    return acc;
  }, {});

const orderedCategories = [
  ...categoryOrder.filter((category) => groupedPosts[category]?.length),
  ...Object.keys(groupedPosts)
    .filter((category) => !categoryOrder.includes(category))
    .sort(),
];

const visualHighlights = [
  { src: '/images/blog/kiyomizudera.jpg', alt: 'Kiyomizu-dera temple view in Kyoto' },
  { src: '/images/blog/gion-maiko.jpg', alt: 'Historic Kyoto street scene in Gion' },
  { src: '/images/blog/higashiyama-pagoda.jpg', alt: 'Kyoto pagoda and mountainscape' },
  { src: '/images/blog/kinkakuji.jpg', alt: 'Golden Pavilion in Kyoto' },
  { src: '/images/blog/arashiyama.jpg', alt: 'Arashiyama riverside and bridge' },
  { src: '/images/blog/arashiyama-bamboo.jpg', alt: 'Arashiyama bamboo grove path' },
  { src: '/images/blog/fushimi-inari.jpg', alt: 'Fushimi Inari shrine gates in Kyoto' },
  { src: '/images/blog/nishiki-market.jpg', alt: 'Nishiki Market food scene' },
  { src: '/images/blog/tea-ceremony.jpg', alt: 'Traditional tea ceremony setting in Kyoto' },
  { src: '/images/blog/uji-matcha.jpg', alt: 'Uji matcha culture near Kyoto' },
];
---

<BaseLayout
  title="Kyoto Travel Guides — OTAtrip Guide Blog"
  description="Practical travel guides for first-time visitors to Kyoto. Planning basics, itineraries, neighborhoods, food, and more — written by local experts."
>
  <!-- Header -->
  <section class="scanlines bg-nes-black py-16 text-center">
    <div class="relative z-10 max-w-4xl mx-auto px-4">
      <p class="font-pixel text-[0.9rem] text-nes-amber mb-4 rpg-prefix">LOCAL KNOWLEDGE</p>
      <h1 class="font-pixel text-nes-white mb-4" style="font-size: clamp(1rem, 4vw, 2rem);">KYOTO TRAVEL GUIDES</h1>
      <p class="font-sans text-gray-400 text-sm max-w-2xl mx-auto leading-relaxed">
        Practical, firsthand guides from local experts who know Kyoto's streets, seasons, and secrets.
      </p>
    </div>
  </section>

  <section class="bg-nes-black border-y-2 border-gray-800 py-10">
    <div class="max-w-6xl mx-auto px-4">
      <div class="flex items-center gap-4 mb-6">
        <h2 class="font-pixel text-[0.95rem] text-nes-cyan">KYOTO PHOTO HIGHLIGHTS</h2>
        <div class="flex-1 border-t border-gray-800"></div>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-5 gap-3">
        {visualHighlights.map((item) => (
          <figure class="overflow-hidden border border-gray-700 bg-black">
            <img
              src={item.src}
              alt={item.alt}
              class="w-full h-32 md:h-36 object-cover hover:scale-105 transition-transform duration-300"
              loading="lazy"
            />
          </figure>
        ))}
      </div>
    </div>
  </section>

  <div class="max-w-6xl mx-auto px-4 py-12">
    {orderedCategories.map((category) => groupedPosts[category]?.length > 0 && (
      <section class="mb-14">
        <div class="flex items-center gap-4 mb-6">
          <h2 class="font-pixel text-[0.95rem] text-nes-amber">{category.toUpperCase()}</h2>
          <div class="flex-1 border-t border-gray-800"></div>
          <span class="font-pixel text-[0.9rem] text-gray-600">{groupedPosts[category].length} GUIDES</span>
        </div>
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
          {groupedPosts[category].map(post => (
            <article class="border-2 border-gray-700 hover:border-nes-amber transition-colors group bg-nes-black">
              <a href={`/blog/${post.slug}`} class="block">
                {post.data.hero_image && (
                  <div class="overflow-hidden border-b-2 border-gray-700">
                    <img
                      src={post.data.hero_image}
                      alt={post.data.title}
                      class="w-full h-44 object-cover group-hover:scale-105 transition-transform duration-300"
                      loading="lazy"
                    />
                  </div>
                )}
                <div class="p-4 md:p-5">
                  <p class="font-pixel text-[0.9rem] text-nes-cyan mb-2">{category.toUpperCase()}</p>
                  <h3 class="font-pixel text-[0.9rem] text-nes-white group-hover:text-nes-amber transition-colors leading-relaxed mb-3">
                    {post.data.title}
                  </h3>
                  <p class="font-sans text-gray-500 text-sm leading-relaxed line-clamp-3 mb-4">{post.data.description}</p>
                  <div class="flex items-center justify-between">
                    <span class="font-pixel text-[0.9rem] text-gray-600">{post.data.author || 'LOCAL GUIDE'}</span>
                    <span class="font-pixel text-[0.9rem] text-nes-cyan">READ &rarr;</span>
                  </div>
                </div>
              </a>
            </article>
          ))}
        </div>
      </section>
    ))}

    {allPosts.length === 0 && (
      <p class="font-pixel text-[0.9rem] text-gray-600 text-center py-20">// TRAVEL GUIDES COMING SOON</p>
    )}
  </div>
</BaseLayout>
