---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');

// Group by category folder (plan, itineraries, etc.)
const categories = {
  'Planning Basics': allPosts.filter(p => p.slug.startsWith('plan/')),
  'Itineraries': allPosts.filter(p => p.slug.startsWith('itineraries/')),
};
---

<BaseLayout
  title="Kyoto Travel Guides — OTA Trip Guide Blog"
  description="Practical travel guides for first-time visitors to Kyoto. Planning basics, itineraries, neighborhoods, food, and more — written by local experts."
>
  <!-- Header -->
  <section class="bg-navy-dark text-white py-16">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <div class="text-gold text-xs font-bold uppercase tracking-widest mb-3">Local Knowledge</div>
      <h1 class="text-4xl md:text-5xl font-bold mb-4">Kyoto Travel Guides</h1>
      <p class="text-gray-300 text-lg max-w-2xl mx-auto">
        Practical, firsthand guides from local experts who know Kyoto's streets, seasons, and secrets.
      </p>
    </div>
  </section>

  <div class="max-w-6xl mx-auto px-4 py-12">
    {Object.entries(categories).map(([category, posts]) => posts.length > 0 && (
      <section class="mb-14">
        <div class="flex items-center gap-4 mb-6">
          <h2 class="text-2xl font-bold text-navy-dark">{category}</h2>
          <div class="flex-1 border-t border-gray-200"></div>
          <span class="text-gray-400 text-sm">{posts.length} guides</span>
        </div>
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
          {posts.map(post => (
            <article class="bg-white border border-gray-200 rounded-xl overflow-hidden shadow-sm hover:shadow-md transition-shadow group">
              <a href={`/blog/${post.slug}`} class="block p-6">
                <div class="text-gold text-xs font-bold uppercase tracking-wider mb-2">{category}</div>
                <h3 class="font-bold text-navy-dark group-hover:text-gold transition-colors leading-snug mb-3 text-lg">
                  {post.data.title}
                </h3>
                <p class="text-gray-500 text-sm leading-relaxed line-clamp-3 mb-4">{post.data.description}</p>
                <div class="flex items-center justify-between text-xs text-gray-400">
                  <span>{post.data.author || 'Local Guide'}</span>
                  <span class="text-gold font-medium">Read &rarr;</span>
                </div>
              </a>
            </article>
          ))}
        </div>
      </section>
    ))}

    <!-- All posts section (catch-all) -->
    {allPosts.filter(p => !p.slug.startsWith('plan/') && !p.slug.startsWith('itineraries/')).length > 0 && (
      <section class="mb-14">
        <div class="flex items-center gap-4 mb-6">
          <h2 class="text-2xl font-bold text-navy-dark">More Guides</h2>
          <div class="flex-1 border-t border-gray-200"></div>
        </div>
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
          {allPosts.filter(p => !p.slug.startsWith('plan/') && !p.slug.startsWith('itineraries/')).map(post => (
            <article class="bg-white border border-gray-200 rounded-xl overflow-hidden shadow-sm hover:shadow-md transition-shadow group">
              <a href={`/blog/${post.slug}`} class="block p-6">
                <h3 class="font-bold text-navy-dark group-hover:text-gold transition-colors leading-snug mb-3 text-lg">
                  {post.data.title}
                </h3>
                <p class="text-gray-500 text-sm leading-relaxed line-clamp-3 mb-4">{post.data.description}</p>
                <div class="text-gold text-xs font-medium">Read guide &rarr;</div>
              </a>
            </article>
          ))}
        </div>
      </section>
    )}

    {allPosts.length === 0 && (
      <p class="text-gray-500 text-center py-20 text-lg">Travel guides coming soon.</p>
    )}
  </div>
</BaseLayout>
