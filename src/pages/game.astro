---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Gion Night Run | OTAtrip Guide"
  description="A mini browser game set in Kyoto's Gion district. Dodge tourists, collect sake cups, survive the night."
  canonical="/game"
>
  <!-- Header -->
  <section class="scanlines bg-nes-black py-10 text-center">
    <div class="relative z-10 max-w-2xl mx-auto px-4">
      <p class="font-pixel text-[0.5rem] text-nes-amber mb-2 rpg-prefix">MINI GAME</p>
      <h1 class="font-pixel text-nes-white mb-3" style="font-size: clamp(0.8rem, 3vw, 1.5rem);">GION NIGHT RUN</h1>
      <p class="font-sans text-sm text-gray-400">Dodge tourists &amp; rickshaws. Collect sake. Survive the night.</p>
    </div>
  </section>

  <div class="max-w-4xl mx-auto px-4 py-8">

    <!-- Game frame -->
    <div class="relative border-4 border-nes-amber bg-nes-black" style="box-shadow: 8px 8px 0 rgba(255,176,0,0.25), -2px -2px 0 rgba(255,176,0,0.1);">

      <!-- HUD bar -->
      <div class="flex justify-between items-center px-4 py-2 border-b-2 border-gray-800">
        <div class="font-pixel text-[0.5rem]">
          <span class="text-nes-cyan">SCORE </span><span class="text-nes-white" id="score-val">0</span>
        </div>
        <div class="font-pixel text-[0.5rem] text-nes-amber">GION NIGHT RUN</div>
        <div class="font-pixel text-[0.5rem]">
          <span class="text-nes-amber">BEST </span><span class="text-nes-white" id="hi-val">0</span>
        </div>
      </div>

      <!-- Canvas -->
      <div class="relative">
        <canvas id="gc" style="width:100%;display:block;image-rendering:pixelated;cursor:pointer;touch-action:none;"></canvas>

        <!-- Start overlay -->
        <div id="start-overlay" class="absolute inset-0 flex flex-col items-center justify-center bg-black/80">
          <p class="font-pixel text-[0.55rem] text-nes-white pixel-cursor mb-4">PRESS SPACE OR TAP TO START</p>
          <div class="flex gap-8 font-sans text-xs text-gray-500">
            <span>🍶 Sake cup = +10 pts</span>
            <span>🚶 Tourist = GAME OVER</span>
            <span>🛻 Rickshaw = GAME OVER</span>
          </div>
        </div>

        <!-- Game over overlay -->
        <div id="over-overlay" style="display:none;" class="absolute inset-0 flex flex-col items-center justify-center bg-black/90">
          <p class="font-pixel text-nes-red mb-4" style="font-size:clamp(0.7rem,2.5vw,1.4rem);">GAME OVER</p>
          <p class="font-pixel text-[0.5rem] text-nes-white mb-1">SCORE: <span id="over-score">0</span></p>
          <p class="font-pixel text-[0.5rem] text-nes-amber mb-6">BEST: <span id="over-hi">0</span></p>
          <div class="flex flex-col sm:flex-row gap-3 items-center">
            <button id="retry-btn" class="nes-btn nes-btn-outline">PLAY AGAIN</button>
            <a href="/tours/gion-sake-walk" class="nes-btn nes-btn-gold">BOOK THE REAL TOUR →</a>
          </div>
        </div>
      </div>
    </div>

    <!-- Controls -->
    <p class="font-sans text-xs text-gray-600 text-center mt-3">
      SPACE · ↑ · TAP to jump &nbsp;|&nbsp; Double jump available
    </p>

    <!-- Back -->
    <div class="text-center mt-10">
      <a href="/tours" class="font-pixel text-[0.5rem] text-nes-amber hover:text-nes-cyan transition-colors">
        &lt; BACK TO TOURS
      </a>
    </div>
  </div>
</BaseLayout>

<script>
(() => {
  const canvas  = document.getElementById('gc');
  const ctx     = canvas.getContext('2d');
  const CW = 800, CH = 220;
  canvas.width  = CW;
  canvas.height = CH;

  const GY = 168;   // top of ground
  const GR = 0.55;  // gravity
  const JV = -13;   // jump velocity
  const PW = 22, PH = 50; // player size

  // ── COLORS ──────────────────────────────────────────────
  const C = {
    sky:'#05050e', ground:'#181510', groundEdge:'#252018',
    face:'#00e5ff', hair:'#1a0800', shirt:'#f0f0f0',
    pants:'#192040', shoe:'#0a0808',
    tourist:'#b0a880', tShirt:'#d0c090', tPants:'#808070',
    rickBody:'#7a3a10', rickDark:'#5a2a08', rickWheel:'#555',
    sake:'#ffb000', sakeLight:'#ffd040',
    amber:'#ffb000', red:'#ff2222', cyan:'#00e5ff',
  };

  // ── STARS ───────────────────────────────────────────────
  const stars = Array.from({length:55}, () => ({
    x: Math.random()*CW, y: Math.random()*(GY-50),
    s: Math.random()>.75?2:1, ph: Math.random()*Math.PI*2,
  }));

  // ── BUILDINGS ───────────────────────────────────────────
  function makeBuildings(n, xSpan, minW, maxW, minH, maxH) {
    return Array.from({length:n}, (_,i) => {
      const w = minW + Math.random()*(maxW-minW);
      const h = minH + Math.random()*(maxH-minH);
      const wRows = Math.max(1, Math.floor((h-15)/20));
      const wCols = Math.max(1, Math.floor((w-12)/18));
      return {
        x: i*xSpan + Math.random()*30, w, h, wRows, wCols,
        wins: Array.from({length:wRows*wCols}, ()=>Math.random()>.4),
      };
    });
  }
  const farB  = makeBuildings(14, 70,  35, 70,  28, 55);
  const nearB = makeBuildings( 9, 110, 60, 100, 55, 90);
  const tiles = Array.from({length:55}, (_,i) => i*18);

  // ── GAME STATE ──────────────────────────────────────────
  let state = 'waiting';
  let score = 0, hi = +(localStorage.getItem('gion-hi')||0);
  let spd = 4, frame = 0;
  let obstacles = [], collectibles = [], particles = [];
  let obstT = 100, collectT = 60;

  const pl = { x:90, y:GY-PH, vy:0, grounded:true, jumps:0, anim:0, squash:1 };

  // ── UI REFS ─────────────────────────────────────────────
  const scoreEl    = document.getElementById('score-val');
  const hiEl       = document.getElementById('hi-val');
  const startEl    = document.getElementById('start-overlay');
  const overEl     = document.getElementById('over-overlay');
  const overScoreEl= document.getElementById('over-score');
  const overHiEl   = document.getElementById('over-hi');
  document.getElementById('retry-btn').addEventListener('click', startGame);

  // ── INPUT ───────────────────────────────────────────────
  function handleInput() {
    if (state==='waiting') startGame();
    else if (state==='playing') doJump();
    else if (state==='gameover') startGame();
  }
  document.addEventListener('keydown', e => {
    if (e.code==='Space'||e.code==='ArrowUp') { e.preventDefault(); handleInput(); }
  });
  canvas.addEventListener('pointerdown', e => { e.preventDefault(); handleInput(); });

  function doJump() {
    if (pl.jumps < 2) {
      pl.vy = JV * (pl.jumps===1 ? 0.82 : 1);
      pl.grounded = false;
      pl.jumps++;
    }
  }

  // ── GAME CONTROL ────────────────────────────────────────
  function startGame() {
    score=0; spd=4; frame=0;
    obstacles=[]; collectibles=[]; particles=[];
    obstT=100; collectT=60;
    Object.assign(pl, {y:GY-PH,vy:0,grounded:true,jumps:0,anim:0,squash:1});
    state='playing';
    startEl.classList.add('hidden');
    overEl.style.display='none';
    updateHUD();
  }

  function endGame() {
    state='gameover';
    if (score>hi) { hi=score; localStorage.setItem('gion-hi',hi); }
    overScoreEl.textContent=score;
    overHiEl.textContent=hi;
    overEl.style.display='flex';
  }

  function updateHUD() {
    scoreEl.textContent=score;
    hiEl.textContent=Math.max(score,hi);
  }

  // ── SPAWN ────────────────────────────────────────────────
  function spawnObs() {
    if (Math.random()<.65)
      obstacles.push({x:CW+20, y:GY-50, w:18, h:50, type:'tourist', af:0});
    else
      obstacles.push({x:CW+20, y:GY-52, w:62, h:52, type:'rickshaw'});
  }

  function spawnCollect() {
    const yOff = 38 + Math.random()*50;
    collectibles.push({x:CW+20, y:GY-yOff-20, w:18, h:20, collected:false, bob:Math.random()*Math.PI*2});
  }

  function hits(a,b,p=4) {
    return a.x+p<b.x+b.w-p && a.x+a.w-p>b.x+p &&
           a.y+p<b.y+b.h-p && a.y+a.h-p>b.y+p;
  }

  // ── UPDATE ──────────────────────────────────────────────
  function update() {
    if (state!=='playing') return;
    frame++;
    spd = 4 + Math.min(score/350, 4.5);

    // Player physics
    pl.vy += GR;
    pl.y  += pl.vy;
    if (pl.y >= GY-PH) {
      if (!pl.grounded && pl.vy>4) pl.squash=0.7;
      pl.y=GY-PH; pl.vy=0; pl.grounded=true; pl.jumps=0;
    }
    pl.squash += (1-pl.squash)*0.2;
    if (pl.grounded && frame%8===0) pl.anim=(pl.anim+1)%4;

    // Score
    if (frame%6===0) { score++; updateHUD(); }

    // Spawn timers
    obstT -= spd;
    if (obstT<=0) { spawnObs(); obstT=72+Math.random()*85; }
    collectT -= spd;
    if (collectT<=0) { spawnCollect(); collectT=58+Math.random()*60; }

    // Move objects
    for (const o of obstacles) { o.x-=spd; if(o.af!==undefined&&frame%10===0) o.af^=1; }
    for (const c of collectibles) { c.x-=spd; c.bob+=0.07; }
    for (const p of particles) { p.x+=p.vx; p.y+=p.vy; p.vy+=0.15; p.life--; }

    obstacles    = obstacles.filter(o=>o.x>-80);
    collectibles = collectibles.filter(c=>c.x>-30&&!c.collected);
    particles    = particles.filter(p=>p.life>0);

    // Scroll bg
    for (const b of farB)  { b.x-=spd*.25; if(b.x+b.w<-5) b.x+=14*70+Math.random()*30; }
    for (const b of nearB) { b.x-=spd*.55; if(b.x+b.w<-5) b.x+=9*110+Math.random()*40; }
    for (let i=0;i<tiles.length;i++) { tiles[i]-=spd; if(tiles[i]<-18) tiles[i]+=55*18; }

    // Collisions
    for (const o of obstacles) { if(hits(pl,o)){endGame();return;} }
    for (const c of collectibles) {
      if (!c.collected && hits(pl,c)) {
        c.collected=true; score+=10;
        for(let i=0;i<10;i++) particles.push({
          x:c.x+9,y:c.y+10,vx:(Math.random()-.5)*4.5,vy:-Math.random()*4.5-1,
          size:3,color:C.sake,life:22,
        });
        updateHUD();
      }
    }
  }

  // ── DRAW HELPERS ────────────────────────────────────────
  function bx(x,y,w,h,col) { ctx.fillStyle=col; ctx.fillRect(~~x,~~y,w,h); }

  function drawBg() {
    bx(0,0,CW,GY,C.sky);
    // Stars
    for (const s of stars) {
      const a=(0.6+0.4*Math.sin(s.ph+frame*.015)).toFixed(2);
      ctx.fillStyle=`rgba(248,248,248,${a})`;
      ctx.fillRect(~~s.x,~~s.y,s.s,s.s);
    }
    // Far buildings
    for (const b of farB) {
      bx(b.x,GY-b.h,b.w,b.h,'#0a0a16');
      let idx=0;
      for (let r=0;r<b.wRows;r++) for (let c=0;c<b.wCols;c++) {
        const wx=b.x+6+c*16, wy=GY-b.h+8+r*18;
        if (wx+8<b.x+b.w-4 && b.wins[idx]) bx(wx,wy,8,6,'#ffb00042');
        idx++;
      }
    }
    // Near buildings
    for (const b of nearB) {
      bx(b.x,GY-b.h,b.w,b.h,'#0e0c1c');
      bx(b.x-3,GY-b.h,b.w+6,5,'#0a0818'); // eave shadow
      let idx=0;
      for (let r=0;r<b.wRows;r++) for (let c=0;c<b.wCols;c++) {
        const wx=b.x+8+c*18, wy=GY-b.h+12+r*22;
        if (wx+10<b.x+b.w-6 && b.wins[idx]) {
          bx(wx,wy,10,8,'#ffb00058');
          bx(wx+1,wy+1,8,2,'#ffd04030');
        }
        idx++;
      }
    }
  }

  function drawGround() {
    bx(0,GY,CW,CH-GY,C.ground);
    bx(0,GY,CW,3,C.groundEdge);
    ctx.strokeStyle='#2a2620'; ctx.lineWidth=1;
    for (const tx of tiles) {
      ctx.strokeRect(~~tx+.5,GY+4.5,16,10);
      ctx.strokeRect(~~tx+9.5,GY+14.5,16,10);
    }
  }

  function drawPlayer() {
    const px=~~pl.x;
    const sy=pl.squash;
    const sh=~~(PH*sy), sw=~~(PW*(2-sy));
    const sox=~~((PW-sw)/2);
    const py=~~(pl.y+PH-sh);
    const af=pl.anim%4;
    const ox=px+sox;

    // Shadow
    ctx.fillStyle='rgba(0,0,0,0.35)';
    ctx.beginPath(); ctx.ellipse(px+PW/2,GY+3,PW/2+2,3.5,0,0,Math.PI*2); ctx.fill();

    // Hair
    bx(ox+3,py,sw-4,~~(5*sy),C.hair);
    // Face
    bx(ox+2,py+~~(4*sy),sw-2,~~(10*sy),C.face);
    // Eye
    bx(ox+sw-8,py+~~(6*sy),2,2,'#0a0820');
    // Shirt
    bx(ox+1,py+~~(14*sy),sw-1,~~(9*sy),C.shirt);
    // Pants
    bx(ox+2,py+~~(23*sy),sw-3,~~(10*sy),C.pants);

    // Legs
    const lp=[{l:-3,r:3},{l:0,r:0},{l:3,r:-3},{l:0,r:0}][af];
    const ly=py+~~(33*sy), lh=~~(13*sy), shh=~~(4*sy);
    const hw=~~(sw/2)-2;
    bx(ox+2+lp.l, ly, hw, lh, C.pants);
    bx(ox+1+lp.l, ly+lh, hw+1, shh, C.shoe);
    bx(ox+~~(sw/2)+1+lp.r, ly, hw, lh, C.pants);
    bx(ox+~~(sw/2)+lp.r,   ly+lh, hw+1, shh, C.shoe);
  }

  function drawObs() {
    for (const o of obstacles) {
      const ox=~~o.x;
      if (o.type==='tourist') {
        // Hat
        bx(ox-1,o.y-6,20,4,'#606050');
        bx(ox+2,o.y-10,14,5,'#606050');
        bx(ox+1,o.y,16,10,C.tourist);    // head
        bx(ox+14,o.y+16,9,7,'#505048'); // camera
        bx(ox+15,o.y+18,5,4,'#333');
        bx(ox,o.y+10,18,13,C.tShirt);   // shirt
        bx(ox-5,o.y+10,7,14,'#6a6a5a'); // backpack
        bx(ox+1,o.y+23,16,13,C.tPants); // pants
        const laf=o.af||0;
        bx(ox+2,o.y+36,6,14+(laf?2:0),'#6a6a5a');
        bx(ox+10,o.y+36,6,14+(laf?0:2),'#6a6a5a');
        bx(ox+1,o.y+48,8,4,'#333');
        bx(ox+10,o.y+48,8,4,'#333');
      } else {
        // Wheels
        for (const wx of [ox+10,ox+48]) {
          ctx.fillStyle=C.rickWheel;
          ctx.beginPath(); ctx.arc(wx,o.y+o.h-7,11,0,Math.PI*2); ctx.fill();
          ctx.fillStyle='#333';
          ctx.beginPath(); ctx.arc(wx,o.y+o.h-7,4,0,Math.PI*2); ctx.fill();
          ctx.strokeStyle='#444'; ctx.lineWidth=1;
          for (let a=0;a<Math.PI*2;a+=Math.PI/3) {
            ctx.beginPath(); ctx.moveTo(wx,o.y+o.h-7);
            ctx.lineTo(wx+Math.cos(a)*9,o.y+o.h-7+Math.sin(a)*9); ctx.stroke();
          }
        }
        // Shafts
        bx(ox-14,o.y+30,20,3,C.rickDark);
        bx(ox-14,o.y+38,20,3,C.rickDark);
        // Puller
        bx(ox-18,o.y+22,10,10,'#c8a878');
        bx(ox-20,o.y+32,14,10,'#a07850');
        bx(ox-18,o.y+42,6,12,'#806040');
        bx(ox-12,o.y+42,6,12,'#806040');
        // Cart
        bx(ox+4,o.y+6,52,26,C.rickBody);
        bx(ox+4,o.y+6,52,4,'#a04818');
        bx(ox+4,o.y+6,3,26,C.rickDark);
        bx(ox+53,o.y+6,3,26,C.rickDark);
        // Roof
        bx(ox+1,o.y+2,58,5,C.rickDark);
        bx(ox-2,o.y-1,64,4,C.rickBody);
        // Passenger
        bx(ox+26,o.y+9,14,11,'#e8d0a0');
        bx(ox+24,o.y+20,18,9,'#c09050');
      }
    }
  }

  function drawCollects() {
    for (const c of collectibles) {
      if (c.collected) continue;
      const cx=~~c.x, cy=~~(c.y+Math.sin(c.bob)*4);
      ctx.fillStyle='rgba(255,176,0,0.12)';
      ctx.beginPath(); ctx.ellipse(cx+9,cy+12,13,13,0,0,Math.PI*2); ctx.fill();
      bx(cx+3,cy,12,3,C.sakeLight);
      bx(cx+2,cy+3,14,11,C.sake);
      bx(cx+3,cy+14,12,3,C.sakeLight);
      bx(cx+5,cy+17,8,2,'#cc8800');
      bx(cx+3,cy+3,12,3,'#ffe566');
    }
  }

  function drawParticles() {
    for (const p of particles) {
      ctx.globalAlpha=Math.max(0,p.life/25);
      ctx.fillStyle=p.color;
      ctx.fillRect(~~p.x,~~p.y,p.size,p.size);
    }
    ctx.globalAlpha=1;
  }

  // ── LOOP ────────────────────────────────────────────────
  function loop() {
    update();
    ctx.clearRect(0,0,CW,CH);
    drawBg();
    drawGround();
    drawCollects();
    drawObs();
    drawPlayer();
    drawParticles();
    requestAnimationFrame(loop);
  }

  hiEl.textContent=hi;
  loop();
})();
</script>
