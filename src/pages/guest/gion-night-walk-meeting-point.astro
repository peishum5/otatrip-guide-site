---
import BaseLayout from '../../layouts/BaseLayout.astro';

const flowSteps = [
  {
    number: '01',
    title: 'Go to Keihan Gion-Shijo Station Exit 2',
    body: 'Come up to street level at Exit 2. Once you are outside, you should immediately see the McDonald\'s sign next to the station entrance.',
  },
  {
    number: '02',
    title: 'Wait beside the wall outside',
    body: 'Stand on the sidewalk between the station entrance and McDonald\'s, beside the dark wall shown in the photo below.',
  },
  {
    number: '03',
    title: 'Look for the guide sign',
    body: 'Your guide will be holding a sign that says "OTAtrip Guide". Please arrive 5 to 10 minutes before the start time.',
  },
];

const missedSteps = [
  'Go back to the exact spot in the photo and wait there.',
  'Check both the station entrance side and the McDonald\'s side for the guide sign.',
  'Send us a message in your booking app immediately.',
  'If messaging is difficult, email us right away.',
  'If the tour has already started, joining later may be difficult.',
];
---

<BaseLayout
  title="Meeting Point: Kyoto Gion Night Walk"
  description="Exact meeting point and backup contact steps for the Kyoto Gion Night Walk."
  canonical="/guest/gion-night-walk-meeting-point"
  noIndex={true}
>
  <section class="border-b border-gray-800 bg-nes-black">
    <div class="mx-auto max-w-3xl px-4 py-14 md:py-18">
      <p class="mb-3 font-pixel text-[0.85rem] text-nes-cyan">GUEST INFO</p>
      <h1 class="mb-4 font-sans text-3xl font-bold leading-tight text-nes-white md:text-4xl">
        Meeting Point
      </h1>
      <p class="font-sans text-base leading-relaxed text-gray-300">
        Please follow the instructions from top to bottom. If you use the photo first, the meeting point should be easy to recognize.
      </p>
    </div>
  </section>

  <div class="mx-auto max-w-3xl px-4 py-10 md:py-12">
    <section class="mb-10 border border-nes-amber bg-[#111111] p-5">
      <p class="mb-2 font-pixel text-[0.8rem] text-nes-amber">MEET HERE</p>
      <p class="font-sans text-base font-semibold leading-relaxed text-nes-white">
        Outside Keihan Gion-Shijo Station Exit 2, beside McDonald&apos;s
      </p>
      <p class="mt-3 font-sans text-sm leading-relaxed text-gray-400">
        Do not wait inside McDonald&apos;s or inside the station gate. Please wait outside on the sidewalk.
      </p>
      <div class="mt-5 flex flex-col gap-3 sm:flex-row">
        <a
          href="https://maps.app.goo.gl/J7SmSwzVmAfjZJs36"
          target="_blank"
          rel="noopener noreferrer"
          class="nes-btn nes-btn-gold text-center"
        >
          OPEN GOOGLE MAPS
        </a>
        <a
          href="mailto:kyoto.otatrip.guide@gmail.com?subject=Cannot%20find%20the%20meeting%20point"
          class="nes-btn nes-btn-outline text-center"
        >
          EMAIL US
        </a>
      </div>
    </section>

    <section class="mb-12">
      <p class="mb-4 font-pixel text-[0.8rem] text-nes-amber">PHOTO REFERENCE</p>
      <img
        src="/images/meeting-points/gion-night-walk-photo.jpg"
        alt="Night view of Keihan Gion-Shijo Station Exit 2 next to McDonald's, with a red circle marking the sidewalk waiting spot beside the wall."
        class="w-full border border-gray-800 bg-black"
        loading="eager"
      />
      <div class="border-x border-b border-gray-800 bg-[#101010] px-5 py-4">
        <p class="font-sans text-sm leading-relaxed text-gray-300">
          The red circle marks the correct waiting spot.
        </p>
        <p class="mt-2 font-sans text-sm leading-relaxed text-gray-500">
          Landmark order: station exit, McDonald&apos;s sign, dark wall, sidewalk waiting area.
        </p>
      </div>
    </section>

    <section class="mb-12">
      <p class="mb-5 font-pixel text-[0.8rem] text-nes-amber">FOLLOW THIS ORDER</p>
      <div class="space-y-4">
        {flowSteps.map((step) => (
          <div class="border border-gray-800 bg-[#111111] px-5 py-5">
            <div class="mb-3 flex items-center gap-3">
              <span class="font-pixel text-[0.8rem] text-nes-green">{step.number}</span>
              <h2 class="font-sans text-lg font-semibold leading-tight text-nes-white">{step.title}</h2>
            </div>
            <p class="font-sans text-sm leading-relaxed text-gray-300">{step.body}</p>
          </div>
        ))}
      </div>
    </section>

    <section class="mb-12 border border-gray-800 bg-[#111111] px-5 py-6">
      <p class="mb-4 font-pixel text-[0.8rem] text-nes-red">IF YOU CAN&apos;T FIND US</p>
      <div class="space-y-3">
        {missedSteps.map((step, index) => (
          <div class="flex items-start gap-3">
            <span class="mt-0.5 shrink-0 font-pixel text-[0.8rem] text-nes-amber">{index + 1}</span>
            <p class="font-sans text-sm leading-relaxed text-gray-300">{step}</p>
          </div>
        ))}
      </div>
      <div class="mt-6 border-t border-gray-800 pt-5">
        <p class="font-sans text-sm leading-relaxed text-gray-400">
          Fastest backup contact: message us in your booking platform. If that is not possible, use the email below.
        </p>
        <a
          href="mailto:kyoto.otatrip.guide@gmail.com?subject=Cannot%20find%20the%20meeting%20point"
          class="mt-4 block border border-nes-amber px-4 py-4 font-pixel text-[0.8rem] text-nes-amber transition-colors hover:bg-nes-amber hover:text-nes-black"
        >
          kyoto.otatrip.guide@gmail.com
        </a>
      </div>
    </section>
  </div>
</BaseLayout>
