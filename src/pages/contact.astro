---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact OTA Trip Guide — Kyoto Tour Inquiries"
  description="Get in touch with OTA Trip Guide for tour bookings, group inquiries, travel agency partnerships, and general questions about Kyoto tours."
  canonical="/contact"
>
  <section class="bg-navy-dark text-white py-16">
    <div class="max-w-2xl mx-auto px-4 text-center">
      <h1 class="text-4xl font-bold mb-4">Contact Us</h1>
      <p class="text-gray-300 text-lg">Questions about tours, group bookings, or anything Kyoto? We reply within 24 hours.</p>
    </div>
  </section>

  <div class="max-w-2xl mx-auto px-4 py-12">
    <!-- Quick links -->
    <div class="grid md:grid-cols-2 gap-4 mb-12">
      <a href="/groups" class="bg-navy-dark text-white rounded-xl p-6 hover:bg-navy transition-colors group">
        <div class="text-gold font-bold text-sm uppercase tracking-wider mb-2">Travel Agencies &amp; Groups</div>
        <div class="text-lg font-semibold group-hover:text-gold transition-colors">Group Inquiry Form &rarr;</div>
        <p class="text-gray-400 text-sm mt-1">Net rates, custom itineraries, large groups</p>
      </a>
      <a href="/tours/gion-sake-walk#booking" class="bg-gray-50 text-navy-dark rounded-xl p-6 hover:bg-gray-100 transition-colors group border border-gray-200">
        <div class="text-gold font-bold text-sm uppercase tracking-wider mb-2">Individual Bookings</div>
        <div class="text-lg font-semibold group-hover:text-gold transition-colors">Book Directly &rarr;</div>
        <p class="text-gray-500 text-sm mt-1">Reserve your spot on the Gion Sake Walk</p>
      </a>
    </div>

    <!-- General contact form -->
    <div class="bg-gray-50 rounded-2xl p-8">
      <h2 class="text-2xl font-bold text-navy-dark mb-6">General Inquiry</h2>

      <form
        name="contact"
        method="POST"
        action="/contact/success"
        class="space-y-5"
        data-netlify="true"
      >
        <input type="hidden" name="form-name" value="contact" />

        <div>
          <label for="name" class="block text-sm font-medium text-gray-700 mb-1">Your Name *</label>
          <input
            type="text"
            id="name"
            name="name"
            required
            class="w-full border border-gray-300 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-gold focus:border-transparent"
            placeholder="Your name"
          />
        </div>

        <div>
          <label for="email" class="block text-sm font-medium text-gray-700 mb-1">Email Address *</label>
          <input
            type="email"
            id="email"
            name="email"
            required
            class="w-full border border-gray-300 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-gold focus:border-transparent"
            placeholder="you@example.com"
          />
        </div>

        <div>
          <label for="subject" class="block text-sm font-medium text-gray-700 mb-1">Subject</label>
          <select
            id="subject"
            name="subject"
            class="w-full border border-gray-300 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-gold focus:border-transparent bg-white"
          >
            <option value="general">General Question</option>
            <option value="booking">Tour Booking Help</option>
            <option value="group">Group / Agency Inquiry</option>
            <option value="other">Other</option>
          </select>
        </div>

        <div>
          <label for="message" class="block text-sm font-medium text-gray-700 mb-1">Message *</label>
          <textarea
            id="message"
            name="message"
            required
            rows="5"
            class="w-full border border-gray-300 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-gold focus:border-transparent resize-none"
            placeholder="Your message..."
          ></textarea>
        </div>

        <button
          type="submit"
          class="w-full bg-gold hover:bg-gold-light text-navy-dark font-bold py-3 rounded-lg transition-colors"
        >
          Send Message
        </button>
      </form>
    </div>

    <!-- Direct email -->
    <div class="mt-8 text-center text-gray-500 text-sm">
      <p>Or email us directly: <a href="mailto:info@otatrip-guide.com" class="text-gold hover:underline font-medium">info@otatrip-guide.com</a></p>
    </div>
  </div>
</BaseLayout>
