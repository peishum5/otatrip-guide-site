---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact | OTAtrip Guide"
  description="Get in touch with OTAtrip Guide for tour bookings, group inquiries, and Kyoto travel questions. We reply within 24 hours."
  canonical="/contact"
>
  <!-- Header -->
  <section class="scanlines bg-nes-black py-16 text-center">
    <div class="relative z-10 max-w-2xl mx-auto px-4">
      <h1 class="font-pixel text-nes-white mb-4" style="font-size: clamp(1rem, 4vw, 2rem);">CONTACT US</h1>
      <p class="font-sans text-gray-400 text-sm">Questions about tours, groups, or anything Kyoto? We reply within 24 hours.</p>
    </div>
  </section>

  <div class="max-w-2xl mx-auto px-4 py-12">

    <!-- Quick links -->
    <div class="grid md:grid-cols-2 gap-4 mb-10">
      <a href="/groups" class="dialogue-box hover:border-nes-cyan transition-colors group block">
        <p class="font-pixel text-[0.9rem] text-nes-cyan mb-2">GROUPS &amp; AGENCIES</p>
        <p class="font-pixel text-[0.9rem] text-nes-white group-hover:text-nes-amber transition-colors mb-1">SEND GROUP INQUIRY &rarr;</p>
        <p class="font-sans text-xs text-gray-500 mt-1">Custom tours, flexible groups</p>
      </a>
      <a href="/tours/gion-sake-walk#booking" class="dialogue-box hover:border-nes-cyan transition-colors group block">
        <p class="font-pixel text-[0.9rem] text-nes-cyan mb-2">INDIVIDUAL BOOKING</p>
        <p class="font-pixel text-[0.9rem] text-nes-white group-hover:text-nes-amber transition-colors mb-1">BOOK A TOUR DIRECTLY &rarr;</p>
        <p class="font-sans text-xs text-gray-500 mt-1">Reserve your spot on a tour</p>
      </a>
    </div>

    <!-- Email CTA -->
    <div class="dialogue-box">
      <h2 class="font-pixel text-[0.9rem] text-nes-white mb-4">// GENERAL INQUIRY</h2>
      <p class="font-sans text-sm text-gray-300 leading-relaxed mb-6">
        Questions about tours, availability, or anything Kyoto-related? Send us an email and we'll get back to you within 24 hours.
      </p>
      <a
        href="mailto:kyoto.otatrip.guide@gmail.com"
        class="nes-btn nes-btn-gold w-full text-center block"
      >
        EMAIL US NOW
      </a>
      <p class="font-sans text-xs text-gray-600 text-center mt-4">kyoto.otatrip.guide@gmail.com</p>
    </div>

  </div>
</BaseLayout>
