---
const navLinks = [
  { href: '/tours', label: 'TOURS' },
  { href: '/blog', label: 'BLOG' },
  { href: '/guide', label: 'OUR GUIDE' },
  { href: '/contact', label: 'CONTACT' },
];
const currentPath = Astro.url.pathname;
---

<header class="bg-nes-black border-b-2 border-nes-amber sticky top-0 z-50">
  <div class="max-w-6xl mx-auto px-4 py-3 flex items-center justify-between">
    <a href="/" class="flex flex-col gap-0.5 group">
      <span class="font-pixel text-[0.65rem] text-nes-amber pixel-flicker leading-tight">OTAtrip GUIDE</span>
      <span class="font-pixel text-[0.5rem] text-nes-cyan leading-tight">KYOTO LOCAL EXPERTS</span>
    </a>

    <!-- Mobile menu button -->
    <button id="mobile-menu-btn" class="md:hidden font-pixel text-[0.5rem] text-nes-amber border border-nes-amber px-3 py-2 hover:bg-nes-amber hover:text-nes-black transition-colors" aria-label="Toggle menu">
      [MENU]
    </button>

    <!-- Desktop nav -->
    <nav class="hidden md:flex items-center gap-6">
      {navLinks.map(link => (
        <a
          href={link.href}
          class={`font-pixel text-[0.5rem] transition-colors hover:text-nes-amber ${currentPath.startsWith(link.href) && link.href !== '/' ? 'text-nes-amber' : 'text-gray-400'}`}
        >
          {link.label}
        </a>
      ))}
      <a href="/groups" class="nes-btn nes-btn-outline" style="font-size: 0.5rem; padding: 0.5rem 0.9rem;">
        GROUPS
      </a>
    </nav>
  </div>

  <!-- Mobile nav -->
  <nav id="mobile-menu" class="hidden md:hidden bg-nes-black border-t border-nes-amber px-4 pb-4">
    {navLinks.map(link => (
      <a
        href={link.href}
        class="block py-3 font-pixel text-[0.5rem] text-gray-400 hover:text-nes-amber transition-colors border-b border-gray-800"
      >
        {link.label}
      </a>
    ))}
    <a href="/groups" class="block py-3 font-pixel text-[0.5rem] text-nes-amber hover:text-nes-black hover:bg-nes-amber transition-colors">
      GROUPS &amp; AGENCIES
    </a>
  </nav>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));
</script>
