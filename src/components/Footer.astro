<footer class="bg-nes-black border-t-2 border-nes-amber mt-16">
  <div class="max-w-6xl mx-auto px-4 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
      <!-- Brand -->
      <div>
        <h3 class="font-pixel text-[1.05rem] text-nes-amber mb-4 pixel-flicker">OTAtrip GUIDE</h3>
        <p class="font-sans text-sm text-gray-400 leading-relaxed">
          Local experts guiding you through Kyoto's best sake bars, hidden alleys, and cultural gems.
          Based in Gion since 2024.
        </p>
      </div>

      <!-- Links -->
      <div>
        <h4 class="font-pixel text-[0.9rem] text-nes-cyan mb-4">// EXPLORE</h4>
        <ul class="space-y-3">
          <li><a href="/tours" class="font-pixel text-[0.9rem] text-gray-400 hover:text-nes-amber transition-colors rpg-prefix">All Tours</a></li>
          <li><a href="/blog" class="font-pixel text-[0.9rem] text-gray-400 hover:text-nes-amber transition-colors rpg-prefix">Travel Blog</a></li>
          <li><a href="/guide" class="font-pixel text-[0.9rem] text-gray-400 hover:text-nes-amber transition-colors rpg-prefix">Our Guides</a></li>
          <li><a href="/groups" class="font-pixel text-[0.9rem] text-gray-400 hover:text-nes-amber transition-colors rpg-prefix">Groups</a></li>
          <li><a href="/contact" class="font-pixel text-[0.9rem] text-gray-400 hover:text-nes-amber transition-colors rpg-prefix">Contact Us</a></li>
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h4 class="font-pixel text-[0.9rem] text-nes-cyan mb-4">// CONTACT</h4>
        <ul class="space-y-3">
          <li class="font-pixel text-[0.9rem] text-gray-400 rpg-prefix">Based in Gion, Kyoto</li>
          <li><a href="mailto:info@otatrip-guide.com" class="font-pixel text-[0.9rem] text-gray-400 hover:text-nes-amber transition-colors rpg-prefix">info@otatrip-guide.com</a></li>
          <li class="pt-2">
            <a href="/groups" class="font-pixel text-[0.9rem] text-nes-amber hover:text-nes-cyan transition-colors">
              &gt; Group inquiries
            </a>
          </li>
        </ul>
      </div>
    </div>

    <div class="border-t border-gray-800 mt-10 pt-6 flex flex-col sm:flex-row justify-between items-center gap-4">
      <p class="font-pixel text-[0.9rem] text-gray-600">&copy; {new Date().getFullYear()} OTAtrip Guide. All rights reserved.</p>
      <p class="font-pixel text-[0.9rem] text-gray-600">
        <a href="/tours" class="hover:text-nes-amber transition-colors">TOURS</a>
        {' · '}
        <a href="/guide" class="hover:text-nes-amber transition-colors">GUIDE</a>
        {' · '}
        <a href="/contact" class="hover:text-nes-amber transition-colors">CONTACT</a>
      </p>
    </div>
  </div>
</footer>
